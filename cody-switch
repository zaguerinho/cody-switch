# === Worktree Helpers ===

# Check if a feature is backed by a git worktree
is_worktree_feature() {
    local name="$1"
    [ -f "$FEATURES_DIR/$name/worktree" ]
}

# Get the worktree path for a feature
get_worktree_path() {
    local name="$1"
    local marker="$FEATURES_DIR/$name/worktree"
    if [ -f "$marker" ]; then
        local path
        path="$(cat "$marker")"
        # Validate path is under WORKTREES_DIR to prevent tampering
        [[ "$path" == "$WORKTREES_DIR/"* ]] || return 1
        echo "$path"
    else
        return 1
    fi
}

# Validate that a feature name is safe for use as a git branch ref
_validate_worktree_name() {
    local name="$1"
    if ! git check-ref-format --branch "worktree-$name" >/dev/null 2>&1; then
        _is_json && _json_error "Invalid feature name for worktree: '${name}' (must be valid git branch name)"
        echo -e "${RED}Error: Invalid feature name for worktree: '${name}'${NC}" >&2
        echo "Feature names used with --worktree must be valid git branch names." >&2
        echo "Avoid spaces, '..', '~', '^', ':', '?', '*', '[', '\\' and leading '-'." >&2
        exit 1
    fi
}

# Create a git worktree for a feature
# Writes the worktree path to the feature's marker file
create_worktree() {
    local name="$1"
    local worktree_dir="$WORKTREES_DIR/$name"
    local branch_name="worktree-$name"

    # Determine base ref (match Codex convention: origin/HEAD, fallback to HEAD)
    local base_ref=""
    base_ref=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/||')
    if [ -z "$base_ref" ]; then
        base_ref="HEAD"
    fi

    mkdir -p "$WORKTREES_DIR"

    # Check if branch already exists
    if git rev-parse --verify "$branch_name" >/dev/null 2>&1; then
        # Branch exists — check if it's already a worktree
        local existing_wt
        existing_wt=$(git worktree list --porcelain 2>/dev/null | grep -A2 "^worktree " | grep -B1 "branch refs/heads/$branch_name" | head -1 | sed 's/^worktree //')
        if [ -n "$existing_wt" ]; then
            _is_json && _json_error "Branch '${branch_name}' is already checked out in worktree: ${existing_wt}"
            echo -e "${RED}Error: Branch '${branch_name}' is already checked out in worktree: ${existing_wt}${NC}" >&2
            exit 1
        fi
        # Reuse existing branch
        git worktree add "$worktree_dir" "$branch_name" >/dev/null 2>&1 || {
            _is_json && _json_error "Failed to create worktree at ${worktree_dir}"
            echo -e "${RED}Error: Failed to create worktree at ${worktree_dir}${NC}" >&2
            exit 1
        }
    else
        # Create new branch
        git worktree add -b "$branch_name" "$worktree_dir" "$base_ref" >/dev/null 2>&1 || {
            _is_json && _json_error "Failed to create worktree at ${worktree_dir}"
            echo -e "${RED}Error: Failed to create worktree at ${worktree_dir}${NC}" >&2
            exit 1
        }
    fi

    # Store worktree path in feature metadata
    echo "$worktree_dir" > "$(get_feature_dir "$name")/worktree"

    # Copy gitignored files from .worktreeinclude
    _copy_worktreeinclude "$worktree_dir"
}

# Copy gitignored files specified in .worktreeinclude to a worktree
_copy_worktreeinclude() {
    local worktree_dir="$1"
    local include_file="$PROJECT_DIR/.worktreeinclude"

    [ -f "$include_file" ] || return 0

    while IFS= read -r pattern || [ -n "$pattern" ]; do
        # Skip comments and empty lines
        [[ "$pattern" =~ ^[[:space:]]*# ]] && continue
        [[ "$pattern" =~ ^[[:space:]]*$ ]] && continue

        # Expand glob relative to project root
        local file
        for file in "$PROJECT_DIR"/$pattern; do
            [ -f "$file" ] || continue
            # Validate file is within project dir (prevent path traversal)
            local real_file
            real_file="$(realpath "$file" 2>/dev/null)" || continue
            [[ "$real_file" == "$PROJECT_DIR"/* ]] || continue
            # Only copy if the file is gitignored
            git check-ignore -q "$file" 2>/dev/null || continue
            local rel="${file#$PROJECT_DIR/}"
            local dest_dir="$worktree_dir/$(dirname "$rel")"
            mkdir -p "$dest_dir"
            cp "$file" "$worktree_dir/$rel"
        done
    done < "$include_file"
}

# Deploy AGENTS.md and tasks from feature storage into its worktree
deploy_to_worktree() {
    local name="$1"
    local wt_path
    wt_path="$(get_worktree_path "$name")" || return 1
    local fdir="$(get_feature_dir "$name")"

    [ -d "$wt_path" ] || return 1

    # Deploy AGENTS.md
    if [ -f "$fdir/AGENTS.md" ]; then
        cp "$fdir/AGENTS.md" "$wt_path/AGENTS.md"
    fi

    # Deploy tasks (safe: copy to temp, verify, then swap)
    if [ -d "$fdir/tasks" ]; then
        local tmp_tasks
        tmp_tasks="$(mktemp -d "$wt_path/tasks.XXXXXX")" && rm -rf "$tmp_tasks"
        rm -rf "$tmp_tasks" 2>/dev/null
        cp -R "$fdir/tasks" "$tmp_tasks"
        if [ -d "$tmp_tasks" ]; then
            rm -rf "$wt_path/tasks"
            mv "$tmp_tasks" "$wt_path/tasks"
        else
            echo -e "${RED}Error: Failed to deploy tasks to worktree${NC}" >&2
            rm -rf "$tmp_tasks" 2>/dev/null
        fi
    fi
}

# Sync AGENTS.md and tasks from a worktree back to feature storage
sync_from_worktree() {
    local name="$1"
    local wt_path
    wt_path="$(get_worktree_path "$name")" || return 1
    local fdir="$(get_feature_dir "$name")"

    [ -d "$wt_path" ] || return 1

    # Sync AGENTS.md
    if [ -f "$wt_path/AGENTS.md" ]; then
        cp "$wt_path/AGENTS.md" "$fdir/AGENTS.md"
    fi

    # Sync tasks (safe: copy to temp, verify, then swap)
    if [ -d "$wt_path/tasks" ]; then
        local tmp_tasks
        tmp_tasks="$(mktemp -d "$fdir/tasks.XXXXXX")" && rm -rf "$tmp_tasks"
        rm -rf "$tmp_tasks" 2>/dev/null
        cp -R "$wt_path/tasks" "$tmp_tasks"
        if [ -d "$tmp_tasks" ]; then
            rm -rf "$fdir/tasks"
            mv "$tmp_tasks" "$fdir/tasks"
        else
            echo -e "${RED}Error: Failed to sync tasks from worktree${NC}" >&2
            rm -rf "$tmp_tasks" 2>/dev/null
        fi
    fi
}

# Remove a worktree and clean up its branch and marker
remove_worktree() {
    local name="$1"
    local force="${2:-false}"
    local wt_path
    wt_path="$(get_worktree_path "$name")" || return 0
    local branch_name="worktree-$name"

    if [ ! -d "$wt_path" ]; then
        # Worktree dir already gone — just clean up marker
        rm -f "$(get_feature_dir "$name")/worktree"
        return 0
    fi

    # Sync state before removal
    sync_from_worktree "$name"

    # Try clean removal first
    if ! git worktree remove "$wt_path" 2>/dev/null; then
        if [ "$force" = true ]; then
            git worktree remove --force "$wt_path" 2>/dev/null || rm -rf "$wt_path"
        else
            _is_json || echo -e "${YELLOW}Warning: Worktree has uncommitted source changes (context files already synced to storage)${NC}"
            git worktree remove --force "$wt_path" 2>/dev/null || rm -rf "$wt_path"
        fi
    fi

    # Clean up branch
    git branch -D "$branch_name" >/dev/null 2>&1 || true

    # Clean up marker
    rm -f "$(get_feature_dir "$name")/worktree"

    # Clean up empty worktrees dir
    rmdir "$WORKTREES_DIR" 2>/dev/null || true
}

# Strip --with reference content from AGENTS.md before saving
strip_reference_contexts() {
    if [ -f "$WITH_REFS_FILE" ] && [ -f "$CLAUDE_MD" ]; then
        # Remove all reference blocks (portable: no sed -i which differs BSD vs GNU)
        local tmpfile
        tmpfile=$(mktemp)
        sed '/<!-- cody-switch-ref:.*:start -->/,/<!-- cody-switch-ref:.*:end -->/d' "$CLAUDE_MD" > "$tmpfile"
        # Remove trailing blank lines left behind
        sed -e :a -e '/^\n*$/{$d;N;ba' -e '}' "$tmpfile" > "$CLAUDE_MD"
        rm -f "$tmpfile"
        rm -f "$WITH_REFS_FILE"
        echo -e "${BLUE}Stripped reference contexts from AGENTS.md${NC}"
    fi
}

# Append a feature's AGENTS.md as read-only reference context
append_reference_context() {
    local ref_name="$1"
    local ref_file="$(get_feature_dir "$ref_name")/AGENTS.md"

    if [ ! -f "$ref_file" ]; then
        echo -e "${RED}Error: Reference feature '${ref_name}' not found${NC}" >&2
        return 1
    fi

    echo "" >> "$CLAUDE_MD"
    echo "<!-- cody-switch-ref:${ref_name}:start -->" >> "$CLAUDE_MD"
    echo "" >> "$CLAUDE_MD"
    echo "---" >> "$CLAUDE_MD"
    echo "# Reference: ${ref_name}" >> "$CLAUDE_MD"
    echo "" >> "$CLAUDE_MD"
    cat "$ref_file" >> "$CLAUDE_MD"
    echo "" >> "$CLAUDE_MD"
    echo "<!-- cody-switch-ref:${ref_name}:end -->" >> "$CLAUDE_MD"

    # Track the reference
    echo "$ref_name" >> "$WITH_REFS_FILE"
}

# Promote lessons from current feature to global lessons file
promote_lesson() {
    local target_level=""
    case "${1:-}" in
        --user)    target_level="user" ;;
        --project) target_level="project" ;;
    esac

    local lessons_file="$TASKS_DIR/lessons.md"

    if [ ! -f "$lessons_file" ]; then
        _is_json && _json_error "No tasks/lessons.md found"
        echo -e "${RED}Error: No tasks/lessons.md found${NC}" >&2
        exit 1
    fi

    # Extract lesson headings (## lines)
    local headings=()
    local line_nums=()
    local i=0
    while IFS= read -r line; do
        i=$((i+1))
        if [[ "$line" =~ ^##\  ]]; then
            headings+=("${line#\#\# }")
            line_nums+=("$i")
        fi
    done < "$lessons_file"

    if [ ${#headings[@]} -eq 0 ]; then
        if _is_json; then
            _json_emit "success" "@bool:true" "command" "promote-lesson" \
                "headings" "@json:[]"
            return
        fi
        echo -e "${YELLOW}No lesson headings (## ...) found in tasks/lessons.md${NC}"
        exit 0
    fi

    # In JSON mode, list headings without prompting
    if _is_json; then
        local _h_json="["
        local _h_first=true
        for idx in "${!headings[@]}"; do
            [ "$_h_first" = true ] && _h_first=false || _h_json+=","
            _h_json+="\"${headings[$idx]}\""
        done
        _h_json+="]"
        local _targets='[{"level":"project","path":".codex/features/lessons-global.md"},{"level":"user","path":"~/.codex/lessons-global.md"}]'
        if [ -n "$target_level" ]; then
            _json_emit "success" "@bool:true" "command" "promote-lesson" \
                "target" "$target_level" \
                "headings" "@json:$_h_json" \
                "targets" "@json:$_targets"
        else
            _json_emit "success" "@bool:true" "command" "promote-lesson" \
                "headings" "@json:$_h_json" \
                "targets" "@json:$_targets"
        fi
        return
    fi

    echo -e "${BOLD}Lessons in tasks/lessons.md:${NC}"
    echo ""
    for idx in "${!headings[@]}"; do
        echo -e "  ${CYAN}$((idx+1)))${NC} ${headings[$idx]}"
    done
    echo ""
    echo -en "${YELLOW}Pick a number (or 'all') to promote:${NC} "
    read -r choice

    # Determine which lessons to promote
    local to_promote=()
    if [ "$choice" = "all" ]; then
        to_promote=("${!headings[@]}")
    elif [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le ${#headings[@]} ]; then
        to_promote=($((choice-1)))
    else
        echo -e "${RED}Invalid choice${NC}" >&2
        exit 1
    fi

    # Ask for destination if no explicit flag
    if [ -z "$target_level" ]; then
        echo ""
        echo -e "${BOLD}Where to promote?${NC}"
        echo -e "  ${CYAN}1)${NC} Project level ${DIM}(.codex/features/lessons-global.md)${NC} ${GREEN}(recommended)${NC}"
        echo -e "  ${CYAN}2)${NC} User level ${DIM}(~/.codex/lessons-global.md)${NC}"
        echo ""
        echo -en "${YELLOW}Pick destination [1]:${NC} "
        read -r dest_choice
        case "${dest_choice:-1}" in
            1) target_level="project" ;;
            2) target_level="user" ;;
            *)
                echo -e "${RED}Invalid choice${NC}" >&2
                exit 1
                ;;
        esac
    fi

    # Resolve target based on chosen level
    local target_file target_label target_display
    if [ "$target_level" = "user" ]; then
        target_file="$CODEX_LESSONS_FILE"
        target_label="user lessons"
        target_display="$target_file"
    else
        target_file="$FEATURES_DIR/lessons-global.md"
        target_label="project lessons"
        target_display=".codex/features/lessons-global.md"
    fi

    # Extract and append each selected lesson
    local target_dir
    target_dir=$(dirname "$target_file")
    mkdir -p "$target_dir"
    local total_lines
    total_lines=$(wc -l < "$lessons_file" | tr -d ' ')

    local header
    if [ "$target_level" = "user" ]; then
        header="# User Lessons"
    else
        header="# Project Lessons"
    fi

    for idx in "${to_promote[@]}"; do
        local start="${line_nums[$idx]}"
        # Find end: next heading or EOF
        local end="$total_lines"
        local next_idx=$((idx+1))
        if [ "$next_idx" -lt ${#line_nums[@]} ]; then
            end=$((${line_nums[$next_idx]} - 1))
        fi
        # Extract the lesson block
        local block
        block=$(sed -n "${start},${end}p" "$lessons_file")
        # Append to target file
        if [ -f "$target_file" ]; then
            echo "" >> "$target_file"
        else
            echo "$header" > "$target_file"
            echo "" >> "$target_file"
        fi
        echo "$block" >> "$target_file"
        echo -e "${GREEN}Promoted: ${headings[$idx]}${NC}"
    done

    echo ""
    echo -e "${GREEN}Lessons saved to ${target_display}${NC}"
}

# Extract headings from a lessons file (## lines) into a newline-separated list
_extract_headings() {
    local file="$1"
    [ -f "$file" ] || return 0
    grep -E '^## ' "$file" | sed 's/^## //' || true
}

# Extract a lesson block from a file given its heading
_extract_block() {
    local file="$1"
    local heading="$2"
    local in_block=0
    local block=""
    while IFS= read -r line; do
        if [ "$in_block" -eq 1 ]; then
            if [[ "$line" =~ ^##\  ]]; then
                break
            fi
            block+="$line"$'\n'
        elif [ "$line" = "## $heading" ]; then
            in_block=1
            block="## $heading"$'\n'
        fi
    done < "$file"
    # Trim trailing blank lines
    echo "$block" | sed -e :a -e '/^[[:space:]]*$/{ $d; N; ba; }'
}

# Audit all features and promote unpromoted lessons
promote_audit() {
    local project_file="$FEATURES_DIR/lessons-global.md"
    local user_file="$CODEX_LESSONS_FILE"
    local current
    current=$(get_current)

    # Collect existing headings from both targets
    local project_headings=""
    local user_headings=""
    if [ -f "$project_file" ]; then
        project_headings=$(_extract_headings "$project_file")
    fi
    if [ -f "$user_file" ]; then
        user_headings=$(_extract_headings "$user_file")
    fi

    # Scan all features for lessons
    # Arrays: lesson_headings[i], lesson_sources[i], lesson_files[i]
    local -a lesson_headings=()
    local -a lesson_sources=()
    local -a lesson_files=()

    # Build list of (file, source_name) pairs to scan
    local -a scan_files=()
    local -a scan_sources=()

    # Active feature
    if [ "$current" != "(none)" ] && [ "$current" != "(active but untracked)" ]; then
        if [ -f "$TASKS_DIR/lessons.md" ]; then
            scan_files+=("$TASKS_DIR/lessons.md")
            scan_sources+=("$current (active)")
        fi
    fi

    # Stored features
    local features
    features=$(get_features)
    for name in $features; do
        [ "$name" = "$current" ] && continue
        local stored="$(get_feature_dir "$name")/tasks/lessons.md"
        if [ -f "$stored" ]; then
            scan_files+=("$stored")
            scan_sources+=("$name")
        fi
    done

    # Scan each file for unpromoted headings
    local si
    for si in "${!scan_files[@]}"; do
        local file="${scan_files[$si]}"
        local source_name="${scan_sources[$si]}"
        local headings_text
        headings_text=$(_extract_headings "$file")
        [ -z "$headings_text" ] && continue
        while IFS= read -r heading; do
            [ -z "$heading" ] && continue
            # Skip if already in project-global
            if [ -n "$project_headings" ] && echo "$project_headings" | grep -qxF "$heading"; then
                continue
            fi
            # Skip if already in user-global
            if [ -n "$user_headings" ] && echo "$user_headings" | grep -qxF "$heading"; then
                continue
            fi
            # Dedup across features
            local already=0
            local k
            for k in "${!lesson_headings[@]}"; do
                if [ "${lesson_headings[$k]}" = "$heading" ]; then
                    lesson_sources[$k]="${lesson_sources[$k]}, $source_name"
                    already=1
                    break
                fi
            done
            if [ "$already" -eq 0 ]; then
                lesson_headings+=("$heading")
                lesson_sources+=("$source_name")
                lesson_files+=("$file")
            fi
        done <<< "$headings_text"
    done

    if [ ${#lesson_headings[@]} -eq 0 ]; then
        if _is_json; then
            _json_emit "success" "@bool:true" "command" "promote-audit" "unpromoted" "@json:[]"
            return
        fi
        echo -e "${GREEN}All lessons are already promoted. Nothing to do.${NC}"
        return
    fi

    if _is_json; then
        local _u_json="["
        local _u_first=true
        for idx in "${!lesson_headings[@]}"; do
            [ "$_u_first" = true ] && _u_first=false || _u_json+=","
            _u_json+="{\"heading\":\"${lesson_headings[$idx]}\",\"sources\":\"${lesson_sources[$idx]}\"}"
        done
        _u_json+="]"
        _json_emit "success" "@bool:true" "command" "promote-audit" \
            "unpromoted" "@json:$_u_json"
        return
    fi

    echo -e "${BOLD}Unpromoted lessons across all features (${#lesson_headings[@]} total):${NC}"
    echo ""
    for idx in "${!lesson_headings[@]}"; do
        echo -e "  ${CYAN}$((idx+1)))${NC} ${lesson_headings[$idx]}"
        echo -e "      ${YELLOW}from:${NC} ${lesson_sources[$idx]}"
    done
    echo ""
    echo -e "Use ${CYAN}cody-switch prompt promote-audit${NC} if you want the bundled review prompt."
}

# List features
list_features() {
    local show_all="$1"
    local current_branch=$(get_branch)
    local project_name=$(basename "$PROJECT_DIR")
    local current=$(get_current)

    if _is_json; then
        # Build JSON via python3 for correct escaping
        local features_json="["
        local first=true
        for feature in $(get_features); do
            local fdir="$(get_feature_dir "$feature")"
            local has_docs=false; [ -d "$DOCS_DIR/$feature" ] && has_docs=true
            local has_tasks=false; [ -d "$fdir/tasks" ] && has_tasks=true
            local has_session=false; ([ -f "$fdir/session" ] || [ -f "$fdir/session-latest" ]) && has_session=true
            local has_worktree=false; local worktree_path=""
            if is_worktree_feature "$feature"; then
                has_worktree=true
                worktree_path="$(get_worktree_path "$feature")"
            fi
            # Escape strings for safe JSON interpolation
            local safe_name="${feature//\\/\\\\}"
            safe_name="${safe_name//\"/\\\"}"
            local safe_wt_path="${worktree_path//\\/\\\\}"
            safe_wt_path="${safe_wt_path//\"/\\\"}"
            local health="ok"
            if [ ! -f "$fdir/AGENTS.md" ] && [ "$feature" != "$current" ]; then
                health="missing_claude_md"
            elif [ -f "$fdir/AGENTS.md" ] && [ ! -s "$fdir/AGENTS.md" ]; then
                health="empty_claude_md"
            fi
            local is_current=false; [ "$feature" = "$current" ] && is_current=true
            [ "$first" = true ] && first=false || features_json+=","
            features_json+="{\"name\":\"$safe_name\",\"current\":$is_current,\"has_docs\":$has_docs,\"has_tasks\":$has_tasks,\"has_session\":$has_session,\"has_worktree\":$has_worktree,\"worktree_path\":\"$safe_wt_path\",\"health\":\"$health\"}"
        done
        features_json+="]"
        local archived_json="["
        first=true
        for feature in $(get_archived_features); do
            local safe_arch="${feature//\\/\\\\}"
            safe_arch="${safe_arch//\"/\\\"}"
            [ "$first" = true ] && first=false || archived_json+=","
            archived_json+="\"$safe_arch\""
        done
        archived_json+="]"
        _json_emit "success" "@bool:true" "command" "list" \
            "project" "$project_name" "branch" "$current_branch" \
            "current" "$current" \
            "features" "@json:$features_json" \
            "archived" "@json:$archived_json" \
            "archived_count" "@int:$(get_archived_features | wc -w | tr -d ' ')"
        return
    fi

    echo -e "${BOLD}Available AGENTS.md contexts:${NC}"
    echo ""
    echo -e "  ${YELLOW}Project:${NC}    ${CYAN}${project_name}${NC} (${PROJECT_DIR})"
    echo -e "  ${YELLOW}Git branch:${NC} ${CYAN}${current_branch}${NC}"
    echo ""

    local i=1

    # Show current active if exists
    if [ -f "$CLAUDE_MD" ]; then
        local active_indicators=""
        if [ -d "$TASKS_DIR" ]; then
            active_indicators=" ${BLUE}[tasks]${NC}"
        fi
        local ref_indicator=""
        if [ -f "$WITH_REFS_FILE" ]; then
            local ref_count
            ref_count=$(wc -l < "$WITH_REFS_FILE" | tr -d ' ')
            ref_indicator=" ${BLUE}(+${ref_count} ref)${NC}"
        fi
        echo -e "  ${GREEN}* ACTIVE: ${current}${NC}${active_indicators}${ref_indicator}"
        echo ""
    fi

    # List all feature files
    local orphan_count=0
    for feature in $(get_features); do
        local indicators=""
        local fdir="$(get_feature_dir "$feature")"
        if [ -d "$DOCS_DIR/$feature" ]; then
            indicators="${indicators} ${BLUE}[docs]${NC}"
        fi
        if [ -d "$fdir/tasks" ]; then
            indicators="${indicators} ${BLUE}[tasks]${NC}"
        fi
        if [ -f "$fdir/session" ] || [ -f "$fdir/session-latest" ]; then
            indicators="${indicators} ${CYAN}[session]${NC}"
        fi
        if is_worktree_feature "$feature"; then
            indicators="${indicators} ${CYAN}[worktree]${NC}"
        fi
        # Warn about missing or empty AGENTS.md
        if [ ! -f "$fdir/AGENTS.md" ] && [ "$feature" != "$current" ]; then
            indicators="${indicators} ${RED}[NO AGENTS.md]${NC}"
            orphan_count=$((orphan_count + 1))
        elif [ -f "$fdir/AGENTS.md" ] && [ ! -s "$fdir/AGENTS.md" ]; then
            indicators="${indicators} ${YELLOW}[empty]${NC}"
        fi
        if [ "$feature" = "$current" ]; then
            echo -e "  ${CYAN}${i})${NC} ${feature} ${GREEN}(current)${NC}${indicators}"
        else
            echo -e "  ${CYAN}${i})${NC} ${feature}${indicators}"
        fi
        i=$((i+1))
    done

    if [ "$orphan_count" -gt 0 ]; then
        echo ""
        echo -e "  ${RED}${orphan_count} feature(s) have lost their AGENTS.md — run 'cody-switch doctor' to diagnose${NC}"
    fi

    echo ""

    # Handle archived features
    local archived=($(get_archived_features))
    local archived_count=${#archived[@]}

    if [ "$archived_count" -gt 0 ]; then
        if [ "$show_all" = "--all" ] || [ "$show_all" = "-a" ]; then
            echo -e "${BOLD}Archived:${NC}"
            echo ""
            for feature in "${archived[@]}"; do
                local indicators=""
                local afdir="$(get_archived_feature_dir "$feature")"
                if [ -d "$DOCS_DIR/archived/$feature" ]; then
                    indicators="${indicators} ${BLUE}[docs]${NC}"
                fi
                if [ -d "$afdir/tasks" ]; then
                    indicators="${indicators} ${BLUE}[tasks]${NC}"
                fi
                echo -e "  ${YELLOW}-${NC} ${feature}${indicators}"
            done
            echo ""
        else
            echo -e "  ${YELLOW}(${archived_count} archived — use 'list --all' to show)${NC}"
            echo ""
        fi
    fi

    echo -e "${YELLOW}Usage:${NC} cody-switch <number> or cody-switch <name>"
}

# Safe file move: cp + verify + rm (prevents data loss on interruption)
safe_move() {
    local src="$1"
    local dst="$2"
    if [ ! -f "$src" ]; then
        echo -e "${RED}Error: safe_move source does not exist: ${src}${NC}" >&2
        return 1
    fi
    cp "$src" "$dst"
    # Verify destination was written: file must exist, and if source had content, dest must too
    if [ ! -f "$dst" ]; then
        echo -e "${RED}Error: safe_move destination was not created: ${dst}${NC}" >&2
        echo -e "${YELLOW}Source preserved at: ${src}${NC}" >&2
        return 1
    fi
    if [ -s "$src" ] && [ ! -s "$dst" ]; then
        echo -e "${RED}Error: safe_move destination is empty but source had content: ${dst}${NC}" >&2
        echo -e "${YELLOW}Source preserved at: ${src}${NC}" >&2
        return 1
    fi
    rm "$src"
}

# Save current AGENTS.md back to its feature file
save_current() {
    # Strip any --with reference content before saving
    strip_reference_contexts

    local current=$(get_current)

    if [ "$current" != "(none)" ] && [ "$current" != "(active but untracked)" ]; then
        # Tracked feature: sync root AGENTS.md back to storage (copy, not move)
        _is_json || echo -e "${BLUE}Saving current context for '${current}'${NC}"
        save_session "$current"
        ensure_feature_dir "$current"
        local dest="$(get_feature_dir "$current")/AGENTS.md"
        if [ -f "$CLAUDE_MD" ]; then
            # Idempotent: skip if content is already identical (avoids dirty git state)
            if [ ! -f "$dest" ] || ! diff -q "$CLAUDE_MD" "$dest" >/dev/null 2>&1; then
                cp "$CLAUDE_MD" "$dest"
            fi
        else
            # Root AGENTS.md is missing (e.g., git checkout restored it to repo version)
            # If feature already has a stored AGENTS.md, keep it; otherwise warn
            if [ ! -f "$dest" ]; then
                _is_json || echo -e "${YELLOW}Warning: No AGENTS.md at project root for '${current}' — feature AGENTS.md may have been lost${NC}"
                _is_json || echo -e "${YELLOW}Creating minimal scaffold to prevent complete data loss${NC}"
                _create_claude_scaffold "$current" "$dest"
            fi
        fi
        save_tasks "$current"
    elif [ "$current" = "(active but untracked)" ] && [ -f "$CLAUDE_MD" ]; then
        if _is_json; then
            # In JSON mode, skip interactive save prompt — leave AGENTS.md in place
            return 0
        fi
        echo ""
        echo -e "${YELLOW}Current AGENTS.md is not tracked by any feature.${NC}"
        echo -en "${YELLOW}Enter a name to save it as (or 'skip' to leave it in place):${NC} "
        read -r save_name

        if [ "$save_name" = "skip" ] || [ -z "$save_name" ]; then
            # NEVER delete root AGENTS.md silently — it may be the repo's committed file
            echo -e "${YELLOW}Leaving AGENTS.md in place (not deleting)${NC}"
            echo -e "${YELLOW}Note: The root AGENTS.md was NOT saved as a feature context${NC}"
        else
            if [ -f "$(get_feature_dir "$save_name")/AGENTS.md" ]; then
                echo -e "${RED}Error: Feature '${save_name}' already exists. Aborting.${NC}" >&2
                return 1
            fi
            ensure_docs_folder "$save_name"
            save_session "$save_name"
            ensure_feature_dir "$save_name"
            cp "$CLAUDE_MD" "$(get_feature_dir "$save_name")/AGENTS.md"
            save_tasks "$save_name"
            echo -e "${GREEN}Saved current AGENTS.md as '${save_name}'${NC}"
        fi
    fi
}

# Save active feature context to storage (for commit workflow)
save_command() {
    local current=$(get_current)
    if [ "$current" = "(none)" ] || [ "$current" = "(active but untracked)" ]; then
        _is_json && _json_error "No active feature to save"
        echo -e "${RED}Error: No active feature to save${NC}" >&2
        return 1
    fi

    # Reuse save_current logic (strips refs, saves session, syncs AGENTS.md + tasks)
    # Use if-guard instead of $? capture — set -e would exit before reaching $? on failure
    if save_current; then
        # Untrack workspace files that are still in git index despite .gitignore
        _untrack_gitignored_workspace
        if _is_json; then
            _json_emit "success" "@bool:true" "command" "save" "feature" "$current"
        else
            echo ""
            echo -e "${GREEN}Feature '${current}' context saved to .codex/features/${current}/${NC}"
            echo -e "${YELLOW}Tip: Stage and commit .codex/features/ to include in your PR${NC}"
        fi
    else
        _is_json && _json_error "Failed to save feature context"
        return 1
    fi
}

# Switch to a feature
switch_to() {
    local target="$1"
    shift
    local with_refs=()

    # Parse --with flags (supports --with name and --with=name)
    while [ $# -gt 0 ]; do
        case "$1" in
            --with=*) with_refs+=("${1#--with=}") ;;
            --with) shift; [ $# -gt 0 ] && with_refs+=("$1") ;;
        esac
        shift
    done

    local feature_file="$(get_feature_dir "$target")/AGENTS.md"
    local current_branch=$(get_branch)

    # Check feature exists first (needed for both classic and worktree paths)
    local feature_dir="$(get_feature_dir "$target")"
    if [ ! -d "$feature_dir" ]; then
        _is_json && _json_error "Feature '${target}' not found"
        echo -e "${RED}Error: Feature '${target}' not found${NC}"
        echo "Available features:"
        get_features | sed 's/^/  /'
        exit 1
    fi

    # Worktree feature: deploy context and print path (no root state change)
    if is_worktree_feature "$target"; then
        local wt_path
        wt_path="$(get_worktree_path "$target")"

        if [ ! -d "$wt_path" ]; then
            _is_json && _json_error "Worktree directory missing: ${wt_path}. Run 'cody-switch doctor' to diagnose."
            echo -e "${RED}Error: Worktree directory missing: ${wt_path}${NC}" >&2
            echo "The worktree marker exists but the directory is gone." >&2
            echo -e "Run ${CYAN}cody-switch doctor${NC} to diagnose." >&2
            exit 1
        fi

        # Warn if --with was used with a worktree target
        if [ ${#with_refs[@]} -gt 0 ]; then
            _is_json || echo -e "${YELLOW}Note: --with is not used for worktree features (they have their own AGENTS.md)${NC}"
        fi

        deploy_to_worktree "$target"

        if _is_json; then
            _json_emit "success" "@bool:true" "command" "switch" \
                "feature" "$target" "worktree" "@bool:true" \
                "worktree_path" "$wt_path"
            return
        fi

        echo ""
        echo -e "${GREEN}Feature '${target}' uses a worktree.${NC}"
        echo -e "${BLUE}Context synced to: ${wt_path}${NC}"
        echo ""
        echo -e "${YELLOW}To start working:${NC}"
        echo -e "  ${CYAN}cd ${wt_path} && codex${NC}"
        echo ""
        return
    fi

    # Classic switch: check for uncommitted changes
    if ! check_uncommitted; then
        _is_json && _json_error "Cannot switch - uncommitted changes detected"
        echo ""
        echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "${RED}ERROR: Cannot switch context - uncommitted changes detected!${NC}"
        echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo ""
        echo -e "  ${YELLOW}Current branch:${NC} ${CYAN}${current_branch}${NC}"
        echo ""
        echo -e "  ${YELLOW}Uncommitted changes:${NC}"
        git status --short | head -10 | sed 's/^/    /'
        local total=$(git status --short | wc -l | tr -d ' ')
        if [ "$total" -gt 10 ]; then
            echo -e "    ${YELLOW}... and $((total - 10)) more${NC}"
        fi
        echo ""
        echo -e "  ${YELLOW}Please commit or stash your changes first:${NC}"
        echo -e "    ${CYAN}git add . && git commit -m \"your message\"${NC}"
        echo -e "    ${CYAN}git stash${NC}"
        echo ""
        exit 1
    fi

    # If AGENTS.md is missing but the feature dir exists (data loss recovery),
    # the switch_to logic below will create a scaffold

    # Validate all --with references exist before switching
    # Note: the currently active feature's AGENTS.md is at project root, not in storage
    local current_feature=$(get_current)
    for ref in "${with_refs[@]}"; do
        [ "$ref" = "$target" ] && continue
        if [ "$ref" = "$current_feature" ]; then
            # Active feature's file is at project root — it will be in storage after save
            continue
        fi
        local ref_file="$(get_feature_dir "$ref")/AGENTS.md"
        if [ ! -f "$ref_file" ]; then
            _is_json && _json_error "Reference feature '${ref}' not found"
            echo -e "${RED}Error: Reference feature '${ref}' not found${NC}" >&2
            exit 1
        fi
    done

    # Save current first
    local previous_feature
    previous_feature="$(get_current)"
    save_current || exit 1

    # Switch to new feature
    _is_json || echo -e "${GREEN}Switching to: ${target}${NC}"
    if [ ! -f "$feature_file" ]; then
        # Feature AGENTS.md is missing (data loss) — create scaffold and warn
        _is_json || echo -e "${YELLOW}Warning: AGENTS.md for '${target}' is missing (possible data loss)${NC}"
        _is_json || echo -e "${YELLOW}Creating minimal scaffold. Run 'cody-switch doctor' for full diagnosis.${NC}"
        _create_claude_scaffold "$target" "$feature_file"
    fi
    cp "$feature_file" "$CLAUDE_MD"
    echo "$target" > "$TRACKER_FILE"
    echo "$target" > "$PROJECT_DIR/.codex-last-seen-feature"
    restore_tasks "$target"

    # Untrack workspace files that are still in git index despite .gitignore
    _untrack_gitignored_workspace

    # Append --with reference contexts
    local applied_refs=()
    if [ ${#with_refs[@]} -gt 0 ]; then
        _is_json || echo ""
        for ref in "${with_refs[@]}"; do
            if [ "$ref" = "$target" ]; then
                _is_json || echo -e "${YELLOW}Skipping --with '${ref}' (same as primary)${NC}"
                continue
            fi
            _is_json || echo -e "${BLUE}Adding reference context: ${ref}${NC}"
            append_reference_context "$ref" || exit 1
            applied_refs+=("$ref")
        done
    fi

    if _is_json; then
        local refs_str=""
        refs_str=$(printf '%s\n' "${applied_refs[@]}")
        _json_emit "success" "@bool:true" "command" "switch" \
            "feature" "$target" "previous" "$previous_feature" \
            "refs" "@array:$refs_str"
        return
    fi

    echo ""
    echo -e "${GREEN}Switched to '${target}'${NC}"

    # Show session resume option if available
    restore_session "$target"

    echo ""
    echo -e "${YELLOW}Codex note:${NC}"
    echo -e "  ${CYAN}AGENTS.md${NC} and ${CYAN}tasks/${NC} are now switched on disk."
    echo -e "  If you changed features mid-session, start a fresh ${CYAN}codex${NC} session for clean context."
    echo ""
}

# Create new feature from current (save current as named)
create_new() {
    local name="$1"

    if [ -z "$name" ]; then
        _is_json && _json_error "Please provide a name for the new feature"
        echo -e "${RED}Error: Please provide a name for the new feature${NC}"
        echo "Usage: cody-switch new <name>"
        exit 1
    fi

    if [ "$name" = "archived" ]; then
        _is_json && _json_error "'archived' is a reserved name"
        echo -e "${RED}Error: 'archived' is a reserved name${NC}" >&2
        exit 1
    fi

    if [ -f "$(get_feature_dir "$name")/AGENTS.md" ]; then
        _is_json && _json_error "Feature '${name}' already exists"
        echo -e "${RED}Error: Feature '${name}' already exists${NC}"
        exit 1
    fi

    if [ -f "$TRACKER_FILE" ]; then
        local current=$(cat "$TRACKER_FILE")
        if [ -n "$current" ]; then
            _is_json && _json_error "Already tracking feature '${current}'"
            echo -e "${RED}Error: Already tracking feature '${current}'${NC}"
            echo "To create a new feature, use: cody-switch blank <name>"
            exit 1
        fi
    fi

    if [ ! -f "$CLAUDE_MD" ]; then
        _is_json || echo -e "${YELLOW}No active AGENTS.md. Creating scaffold for '${name}'${NC}"
        _create_claude_scaffold "$name" "$CLAUDE_MD"
    fi

    ensure_docs_folder "$name"
    echo "$name" > "$TRACKER_FILE"

    # Persist AGENTS.md and tasks to storage immediately
    ensure_feature_dir "$name"
    cp "$CLAUDE_MD" "$(get_feature_dir "$name")/AGENTS.md"
    save_tasks "$name"

    if _is_json; then
        _json_emit "success" "@bool:true" "command" "new" "feature" "$name"
        return
    fi
    echo -e "${GREEN}Created new feature context: ${name}${NC}"
    echo "Current AGENTS.md is now tracked as '${name}'"
}

# Create a blank feature context
create_blank() {
    local name=""
    local use_workflow=false
    local use_branch=false
    local use_worktree=false

    # Parse arguments
    for arg in "$@"; do
        case "$arg" in
            --workflow)  use_workflow=true ;;
            --branch)    use_branch=true ;;
            --worktree)  use_worktree=true ;;
            --with=*|--with)
                echo -e "${RED}Error: --with is not supported with 'blank'${NC}" >&2
                echo "Create the feature first, then switch with --with:" >&2
                echo "  cody-switch blank <name>" >&2
                echo "  cody-switch <name> --with <ref>" >&2
                exit 1
                ;;
            *)          name="$arg" ;;
        esac
    done

    if [ -z "$name" ]; then
        _is_json && _json_error "Please provide a name for the new feature"
        echo -e "${RED}Error: Please provide a name for the new feature${NC}"
        echo "Usage: cody-switch blank <name> [--workflow] [--branch] [--worktree]"
        exit 1
    fi

    if [ "$name" = "archived" ]; then
        _is_json && _json_error "'archived' is a reserved name"
        echo -e "${RED}Error: 'archived' is a reserved name${NC}" >&2
        exit 1
    fi

    # --worktree and --branch are mutually exclusive
    if [ "$use_worktree" = true ] && [ "$use_branch" = true ]; then
        _is_json && _json_error "--worktree and --branch are mutually exclusive (worktree creates its own branch)"
        echo -e "${RED}Error: --worktree and --branch are mutually exclusive${NC}" >&2
        echo "Worktree creates its own branch (worktree-<name>) automatically." >&2
        exit 1
    fi

    if [ -f "$(get_feature_dir "$name")/AGENTS.md" ]; then
        _is_json && _json_error "Feature '${name}' already exists"
        echo -e "${RED}Error: Feature '${name}' already exists${NC}"
        exit 1
    fi

    # Validate name for git branch compatibility when using worktree
    if [ "$use_worktree" = true ]; then
        _validate_worktree_name "$name"
    fi

    ensure_feature_dir "$name"
    local feature_file="$(get_feature_dir "$name")/AGENTS.md"
    local branch_created=false
    local worktree_path=""

    # Seed with workflow template if --workflow flag is passed, otherwise minimal scaffold
    if [ "$use_workflow" = true ]; then
        if [ -f "$WORKFLOW_TEMPLATE" ]; then
            python3 -c "import sys; print(sys.stdin.read().replace('{feature-name}', sys.argv[1]), end='')" "$name" < "$WORKFLOW_TEMPLATE" > "$feature_file"
            _is_json || echo -e "${GREEN}Created feature context '${name}' (from workflow.md)${NC}"
        else
            _create_claude_scaffold "$name" "$feature_file"
            _is_json || echo -e "${GREEN}Created feature context: ${name} (minimal scaffold)${NC}"
            _is_json || echo -e "${YELLOW}Warning: workflow.md template not found at ${WORKFLOW_TEMPLATE}${NC}"
        fi
    else
        _create_claude_scaffold "$name" "$feature_file"
        _is_json || echo -e "${GREEN}Created feature context: ${name}${NC}"
    fi
    ensure_docs_folder "$name"

    # Create git worktree if --worktree flag is passed
    if [ "$use_worktree" = true ]; then
        create_worktree "$name"
        deploy_to_worktree "$name"
        worktree_path="$WORKTREES_DIR/$name"
        _is_json || echo -e "${GREEN}Created worktree at: ${CYAN}${worktree_path}${NC}"
        _is_json || echo -e "${GREEN}Branch: ${CYAN}worktree-${name}${NC}"
    fi

    # Create and checkout new branch if --branch flag is passed
    if [ "$use_branch" = true ]; then
        if git rev-parse --verify "$name" >/dev/null 2>&1; then
            _is_json || echo -e "${YELLOW}Branch '${name}' already exists, checking out${NC}"
            git checkout "$name"
        else
            git checkout -b "$name"
            branch_created=true
            _is_json || echo -e "${GREEN}Created and switched to branch '${name}'${NC}"
        fi
    fi

    if _is_json; then
        local has_worktree=false
        [ "$use_worktree" = true ] && has_worktree=true
        _json_emit "success" "@bool:true" "command" "blank" "feature" "$name" \
            "workflow" "@bool:$use_workflow" "branch_created" "@bool:$branch_created" \
            "has_worktree" "@bool:$has_worktree" "worktree_path" "$worktree_path"
        return
    fi

    echo ""

    if [ "$use_worktree" = true ]; then
        # Worktree features: print path instead of switch prompt
        echo -e "${YELLOW}To start working in the worktree:${NC}"
        echo -e "  ${CYAN}cd ${worktree_path} && claude${NC}"
    else
        # Ask if they want to switch
        echo -e "${YELLOW}Switch to '${name}' now?${NC} [y/N] "
        read -r response

        if [[ "$response" =~ ^[Yy]$ ]]; then
            switch_to "$name"
        else
            echo ""
            echo -e "To switch later, run: ${CYAN}cody-switch ${name}${NC}"
        fi
    fi
}

# Fork a feature: copy AGENTS.md (always), tasks and docs (optionally) from a source
fork_feature() {
    local source=""
    local name=""
    local without_docs=false
    local without_tasks=false
    local use_branch=false
    local use_worktree=false

    # Parse arguments
    for arg in "$@"; do
        case "$arg" in
            --without-docs)  without_docs=true ;;
            --without-tasks) without_tasks=true ;;
            --branch)        use_branch=true ;;
            --worktree)      use_worktree=true ;;
            *)
                if [ -z "$source" ]; then
                    source="$arg"
                elif [ -z "$name" ]; then
                    name="$arg"
                fi
                ;;
        esac
    done

    if [ -z "$source" ] || [ -z "$name" ]; then
        _is_json && _json_error "Both source and new name are required"
        echo -e "${RED}Error: Both source and new name are required${NC}" >&2
        echo "Usage: cody-switch fork <source> <new-name> [--without-docs] [--without-tasks] [--branch] [--worktree]" >&2
        exit 1
    fi

    if [ "$name" = "archived" ]; then
        _is_json && _json_error "'archived' is a reserved name"
        echo -e "${RED}Error: 'archived' is a reserved name${NC}" >&2
        exit 1
    fi

    # --worktree and --branch are mutually exclusive
    if [ "$use_worktree" = true ] && [ "$use_branch" = true ]; then
        _is_json && _json_error "--worktree and --branch are mutually exclusive (worktree creates its own branch)"
        echo -e "${RED}Error: --worktree and --branch are mutually exclusive${NC}" >&2
        echo "Worktree creates its own branch (worktree-<name>) automatically." >&2
        exit 1
    fi

    if [ -f "$(get_feature_dir "$name")/AGENTS.md" ]; then
        _is_json && _json_error "Feature '${name}' already exists"
        echo -e "${RED}Error: Feature '${name}' already exists${NC}" >&2
        exit 1
    fi

    # Validate name for git branch compatibility when using worktree
    if [ "$use_worktree" = true ]; then
        _validate_worktree_name "$name"
    fi

    # Sync source worktree before forking to get latest content
    if is_worktree_feature "$source"; then
        sync_from_worktree "$source"
    fi

    # Resolve source location
    local source_claude=""
    local source_tasks=""
    local source_docs=""
    local current
    current="$(get_current)"

    if [ "$source" = "$current" ]; then
        # Active feature: AGENTS.md and tasks/ at project root
        source_claude="$CLAUDE_MD"
        [ -d "$TASKS_DIR" ] && source_tasks="$TASKS_DIR"
        [ -d "$DOCS_DIR/$source" ] && source_docs="$DOCS_DIR/$source"
    elif [ -f "$(get_feature_dir "$source")/AGENTS.md" ]; then
        # Stored feature
        source_claude="$(get_feature_dir "$source")/AGENTS.md"
        [ -d "$(get_feature_dir "$source")/tasks" ] && source_tasks="$(get_feature_dir "$source")/tasks"
        [ -d "$DOCS_DIR/$source" ] && source_docs="$DOCS_DIR/$source"
    elif [ -f "$(get_archived_feature_dir "$source")/AGENTS.md" ]; then
        # Archived feature
        source_claude="$(get_archived_feature_dir "$source")/AGENTS.md"
        [ -d "$(get_archived_feature_dir "$source")/tasks" ] && source_tasks="$(get_archived_feature_dir "$source")/tasks"
        local archived_docs="$DOCS_DIR/archived/$source"
        [ -d "$archived_docs" ] && source_docs="$archived_docs"
    else
        _is_json && _json_error "Source feature '${source}' not found"
        echo -e "${RED}Error: Source feature '${source}' not found${NC}" >&2
        exit 1
    fi

    # Create new feature
    ensure_feature_dir "$name"
    local new_dir
    new_dir="$(get_feature_dir "$name")"

    # Always copy AGENTS.md
    cp "$source_claude" "$new_dir/AGENTS.md"

    # Tasks
    if [ "$without_tasks" = true ] || [ -z "$source_tasks" ]; then
        create_fresh_tasks "$new_dir/tasks"
    else
        cp -r "$source_tasks" "$new_dir/tasks"
    fi

    # Docs
    if [ "$without_docs" = true ] || [ -z "$source_docs" ]; then
        ensure_docs_folder "$name"
    else
        cp -r "$source_docs" "$DOCS_DIR/$name"
    fi

    local branch_created=false
    local worktree_path=""
    _is_json || echo -e "${GREEN}Forked '${source}' → '${name}'${NC}"

    # Create git worktree if --worktree flag is passed
    if [ "$use_worktree" = true ]; then
        create_worktree "$name"
        deploy_to_worktree "$name"
        worktree_path="$WORKTREES_DIR/$name"
        _is_json || echo -e "${GREEN}Created worktree at: ${CYAN}${worktree_path}${NC}"
        _is_json || echo -e "${GREEN}Branch: ${CYAN}worktree-${name}${NC}"
    fi

    # Create and checkout new branch if --branch flag is passed
    if [ "$use_branch" = true ]; then
        if git rev-parse --verify "$name" >/dev/null 2>&1; then
            _is_json || echo -e "${YELLOW}Branch '${name}' already exists, checking out${NC}"
            git checkout "$name"
        else
            git checkout -b "$name"
            branch_created=true
            _is_json || echo -e "${GREEN}Created and switched to branch '${name}'${NC}"
        fi
    fi

    local copied_tasks=true
    [ "$without_tasks" = true ] && copied_tasks=false
    [ -z "$source_tasks" ] && copied_tasks=false
    local copied_docs=true
    [ "$without_docs" = true ] && copied_docs=false
    [ -z "$source_docs" ] && copied_docs=false

    if _is_json; then
        local has_worktree=false
        [ "$use_worktree" = true ] && has_worktree=true
        _json_emit "success" "@bool:true" "command" "fork" \
            "source" "$source" "feature" "$name" \
            "branch_created" "@bool:$branch_created" \
            "has_worktree" "@bool:$has_worktree" "worktree_path" "$worktree_path" \
            "copied" "@json:{\"claude_md\":true,\"tasks\":$copied_tasks,\"docs\":$copied_docs}"
        return
    fi

    echo ""

    if [ "$use_worktree" = true ]; then
        # Worktree features: print path instead of switch prompt
        echo -e "${YELLOW}To start working in the worktree:${NC}"
        echo -e "  ${CYAN}cd ${worktree_path} && claude${NC}"
    else
        # Ask if they want to switch
        echo -e "${YELLOW}Switch to '${name}' now?${NC} [y/N] "
        read -r response

        if [[ "$response" =~ ^[Yy]$ ]]; then
            switch_to "$name"
        else
            echo ""
            echo -e "To switch later, run: ${CYAN}cody-switch ${name}${NC}"
        fi
    fi
}

# Archive a feature
archive_feature() {
    local name="$1"

    if [ -z "$name" ]; then
        _is_json && _json_error "Please provide a feature name to archive"
        echo -e "${RED}Error: Please provide a feature name to archive${NC}" >&2
        echo "Usage: cody-switch archive <name>" >&2
        exit 1
    fi

    # Block if feature is currently active
    local current=$(get_current)
    if [ "$current" = "$name" ]; then
        _is_json && _json_error "Cannot archive the active feature '${name}'"
        echo -e "${RED}Error: Cannot archive the active feature '${name}'${NC}" >&2
        echo "Switch to another feature first." >&2
        exit 1
    fi

    local fdir="$(get_feature_dir "$name")"
    if [ ! -d "$fdir" ]; then
        _is_json && _json_error "Feature '${name}' not found"
        echo -e "${RED}Error: Feature '${name}' not found${NC}" >&2
        exit 1
    fi

    # Clean up worktree if this is a worktree-backed feature
    if is_worktree_feature "$name"; then
        _is_json || echo -e "${BLUE}Syncing and removing worktree for '${name}'...${NC}"
        remove_worktree "$name"
    fi

    # Move entire feature dir to archived/
    mkdir -p "$FEATURES_DIR/archived"
    mv "$fdir" "$(get_archived_feature_dir "$name")"

    # Move docs folder
    if [ -d "$DOCS_DIR/$name" ]; then
        mkdir -p "$DOCS_DIR/archived"
        mv "$DOCS_DIR/$name" "$DOCS_DIR/archived/$name"
    fi

    if _is_json; then
        _json_emit "success" "@bool:true" "command" "archive" "feature" "$name"
        return
    fi
    echo -e "${GREEN}Archived feature '${name}'${NC}"
}

# Unarchive a feature
unarchive_feature() {
    local name="$1"

    if [ -z "$name" ]; then
        _is_json && _json_error "Please provide a feature name to unarchive"
        echo -e "${RED}Error: Please provide a feature name to unarchive${NC}" >&2
        echo "Usage: cody-switch unarchive <name>" >&2
        exit 1
    fi

    local afdir="$(get_archived_feature_dir "$name")"
    if [ ! -d "$afdir" ]; then
        _is_json && _json_error "Archived feature '${name}' not found"
        echo -e "${RED}Error: Archived feature '${name}' not found${NC}" >&2
        exit 1
    fi

    # Block if an active (non-archived) feature with the same name exists
    if [ -d "$(get_feature_dir "$name")" ]; then
        _is_json && _json_error "A feature named '${name}' already exists"
        echo -e "${RED}Error: A feature named '${name}' already exists${NC}" >&2
        echo "Delete or rename the existing feature first." >&2
        exit 1
    fi

    # Move entire feature dir back from archived/
    mv "$afdir" "$(get_feature_dir "$name")"

    # Remove stale worktree marker if present (worktree was removed during archive)
    local restored_dir="$(get_feature_dir "$name")"
    if [ -f "$restored_dir/worktree" ]; then
        _is_json || echo -e "${YELLOW}Note: Removed stale worktree marker (worktree was cleaned up during archive)${NC}"
        rm -f "$restored_dir/worktree"
    fi

    # Clean up archived dir if empty
    rmdir "$FEATURES_DIR/archived" 2>/dev/null || true

    # Move docs folder back
    if [ -d "$DOCS_DIR/archived/$name" ]; then
        mv "$DOCS_DIR/archived/$name" "$DOCS_DIR/$name"
        rmdir "$DOCS_DIR/archived" 2>/dev/null || true
    fi

    if _is_json; then
        _json_emit "success" "@bool:true" "command" "unarchive" "feature" "$name"
        return
    fi
    echo -e "${GREEN}Unarchived feature '${name}'${NC}"
}

# Peek at a feature's AGENTS.md without switching
peek_feature() {
    local target="$1"

    if [ -z "$target" ]; then
        echo -e "${RED}Error: Please provide a feature name or number${NC}" >&2
        echo "Usage: cody-switch peek <name|number>" >&2
        exit 1
    fi

    # Resolve number to name
    if [[ "$target" =~ ^[0-9]+$ ]]; then
        local features=($(get_features))
        local index=$(($target - 1))

        if [ $index -lt 0 ] || [ $index -ge ${#features[@]} ]; then
            echo -e "${RED}Error: Invalid number. Use 1-${#features[@]}${NC}" >&2
            exit 1
        fi

        target="${features[$index]}"
    fi

    # Check if it's the active feature
    local current=$(get_current)
    if [ "$target" = "$current" ] && [ -f "$CLAUDE_MD" ]; then
        if _is_json; then
            _json_emit "success" "@bool:true" "command" "peek" "feature" "$target" \
                "status" "active" "content" "$(cat "$CLAUDE_MD")"
            return
        fi
        echo -e "${BOLD}=== ${target} (active) ===${NC}"
        echo ""
        cat "$CLAUDE_MD"
        return
    fi

    # Check non-archived
    local fdir="$(get_feature_dir "$target")"
    if [ -d "$fdir" ]; then
        if [ -f "$fdir/AGENTS.md" ]; then
            if _is_json; then
                _json_emit "success" "@bool:true" "command" "peek" "feature" "$target" \
                    "status" "stored" "content" "$(cat "$fdir/AGENTS.md")"
                return
            fi
            echo -e "${BOLD}=== ${target} ===${NC}"
            echo ""
            cat "$fdir/AGENTS.md"
        else
            if _is_json; then
                _json_emit "success" "@bool:true" "command" "peek" "feature" "$target" \
                    "status" "missing_claude_md" "content" ""
                return
            fi
            echo -e "${BOLD}=== ${target} ===${NC}"
            echo ""
            echo -e "${RED}AGENTS.md is missing for this feature (data loss detected)${NC}"
            echo -e "${YELLOW}Existing artifacts: $(ls "$fdir" | tr '\n' ', ')${NC}"
            echo -e "${YELLOW}Run 'cody-switch doctor' for full diagnosis${NC}"
        fi
        return
    fi

    # Check archived
    local afdir="$(get_archived_feature_dir "$target")"
    if [ -d "$afdir" ]; then
        if [ -f "$afdir/AGENTS.md" ]; then
            if _is_json; then
                _json_emit "success" "@bool:true" "command" "peek" "feature" "$target" \
                    "status" "archived" "content" "$(cat "$afdir/AGENTS.md")"
                return
            fi
            echo -e "${BOLD}=== ${target} (archived) ===${NC}"
            echo ""
            cat "$afdir/AGENTS.md"
        else
            if _is_json; then
                _json_emit "success" "@bool:true" "command" "peek" "feature" "$target" \
                    "status" "archived_missing_claude_md" "content" ""
                return
            fi
            echo -e "${BOLD}=== ${target} (archived) ===${NC}"
            echo ""
            echo -e "${RED}AGENTS.md is missing for this archived feature (data loss detected)${NC}"
        fi
        return
    fi

    _is_json && _json_error "Feature '${target}' not found"
    echo -e "${RED}Error: Feature '${target}' not found${NC}" >&2
    exit 1
}

# Delete a feature and all its artifacts
delete_feature() {
    local name="$1"

    if [ -z "$name" ]; then
        _is_json && _json_error "Please provide a feature name to delete"
        echo -e "${RED}Error: Please provide a feature name to delete${NC}" >&2
        echo "Usage: cody-switch delete <name>" >&2
        exit 1
    fi

    # Block if feature is currently active
    local current=$(get_current)
    if [ "$current" = "$name" ]; then
        _is_json && _json_error "Cannot delete the active feature '${name}'"
        echo -e "${RED}Error: Cannot delete the active feature '${name}'${NC}" >&2
        echo "Switch to another feature first." >&2
        exit 1
    fi

    # Check the feature exists (in any form)
    local found=false
    local to_delete=()

    # Check for worktree
    local has_worktree=false
    local wt_path=""
    if is_worktree_feature "$name"; then
        has_worktree=true
        wt_path="$(get_worktree_path "$name")"
    fi

    for f in \
        "$(get_feature_dir "$name")" \
        "$(get_archived_feature_dir "$name")" \
        "$DOCS_DIR/${name}" \
        "$DOCS_DIR/archived/${name}"; do
        if [ -e "$f" ]; then
            found=true
            to_delete+=("$f")
        fi
    done

    if [ "$found" = false ]; then
        _is_json && _json_error "Feature '${name}' not found"
        echo -e "${RED}Error: Feature '${name}' not found${NC}" >&2
        exit 1
    fi

    # In JSON mode, auto-confirm
    if ! _is_json; then
        echo -e "${YELLOW}The following will be deleted:${NC}"
        for f in "${to_delete[@]}"; do
            echo -e "  ${RED}-${NC} ${f#$PROJECT_DIR/}"
        done
        if [ "$has_worktree" = true ] && [ -d "$wt_path" ]; then
            echo -e "  ${RED}-${NC} ${wt_path#$PROJECT_DIR/} (worktree)"
            echo -e "  ${RED}-${NC} branch worktree-${name}"
        fi
        echo ""
        echo -en "${YELLOW}Delete '${name}'? This cannot be undone.${NC} [y/N] "
        read -r response
        if [[ ! "$response" =~ ^[Yy]$ ]]; then
            echo "Aborted."
            return
        fi
    fi

    # Remove worktree first (syncs state, removes branch)
    if [ "$has_worktree" = true ]; then
        remove_worktree "$name" true
    fi

    for f in "${to_delete[@]}"; do
        rm -rf "$f"
    done

    # Clean up empty archived dirs
    rmdir "$DOCS_DIR/archived" 2>/dev/null || true
    rmdir "$FEATURES_DIR/archived" 2>/dev/null || true

    if _is_json; then
        _json_emit "success" "@bool:true" "command" "delete" "feature" "$name"
        return
    fi
    echo -e "${GREEN}Deleted feature '${name}'${NC}"
}

# Diagnose feature health: find missing/empty AGENTS.md, orphaned data
doctor() {
    local fix_mode=false
    [ "$1" = "--fix" ] && fix_mode=true

    local issues=0
    local fixed=0
    local current
    current=$(get_current)

    # JSON collection variables
    local _json_features="["
    local _json_first=true

    if ! _is_json; then
        if [ "$fix_mode" = true ]; then
            echo -e "${BOLD}cody-switch doctor --fix — Fixing Feature Issues${NC}"
        else
            echo -e "${BOLD}cody-switch doctor — Feature Health Report${NC}"
        fi
        echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo ""
    fi

    # 1. Current active feature status
    _is_json || echo -e "${BOLD}Active Feature${NC}"
    _is_json || echo -e "  Tracker:    ${CYAN}${current}${NC}"
    if [ -f "$CLAUDE_MD" ]; then
        local md_size
        md_size=$(wc -c < "$CLAUDE_MD" | tr -d ' ')
        _is_json || echo -e "  Root AGENTS.md: ${GREEN}exists${NC} (${md_size} bytes)"
        if git show HEAD:AGENTS.md >/dev/null 2>&1; then
            if diff -q "$CLAUDE_MD" <(git show HEAD:AGENTS.md 2>/dev/null) >/dev/null 2>&1; then
                _is_json || echo -e "  ${YELLOW}Note: Root AGENTS.md matches git HEAD — this is the repo file, NOT a feature file${NC}"
                if [ "$current" != "(none)" ] && [ "$current" != "(active but untracked)" ]; then
                    _is_json || echo -e "  ${RED}ISSUE: Feature '${current}' is tracked as active but root AGENTS.md is the repo version${NC}"
                    _is_json || echo -e "  ${RED}       This means the feature's AGENTS.md was lost during a previous switch${NC}"
                    issues=$((issues + 1))
                fi
            fi
        fi
    else
        _is_json || echo -e "  Root AGENTS.md: ${RED}MISSING${NC}"
        if [ "$current" != "(none)" ]; then
            _is_json || echo -e "  ${RED}ISSUE: Feature '${current}' is active but has no AGENTS.md at project root${NC}"
            issues=$((issues + 1))
        fi
    fi
    _is_json || echo ""

    # 2. Scan all feature folders
    _is_json || echo -e "${BOLD}Feature Scan${NC}"
    if [ ! -d "$FEATURES_DIR" ]; then
        _is_json || echo -e "  ${YELLOW}No features directory found${NC}"
        _is_json || echo ""
    else
        local total=0
        local healthy=0
        local missing_md=0
        local empty_md=0
        local orphaned_sessions=0
        local orphaned_tasks=0

        for d in "$FEATURES_DIR"/*/; do
            [ -d "$d" ] || continue
            local name="$(basename "$d")"
            [ "$name" = "archived" ] && continue
            total=$((total + 1))

            local has_claude=false
            local has_content=false
            local has_session=false
            local has_tasks=false

            if [ -f "$d/AGENTS.md" ]; then
                has_claude=true
                [ -s "$d/AGENTS.md" ] && has_content=true
            fi
            if [ -f "$d/session" ] || [ -f "$d/session-latest" ]; then
                has_session=true
            fi
            if [ -d "$d/tasks" ]; then
                has_tasks=true
            fi

            # Skip the active feature (its AGENTS.md is at project root)
            if [ "$name" = "$current" ]; then
                if [ "$has_claude" = false ] && [ -f "$CLAUDE_MD" ]; then
                    # Expected: active feature's AGENTS.md is at root
                    healthy=$((healthy + 1))
                    continue
                elif [ "$has_claude" = true ]; then
                    # AGENTS.md in both places — unusual but not broken
                    healthy=$((healthy + 1))
                    continue
                fi
            fi

            local _feat_health="healthy"
            local _feat_fixed=false

            if [ "$has_claude" = true ] && [ "$has_content" = true ]; then
                healthy=$((healthy + 1))
            elif [ "$has_claude" = true ] && [ "$has_content" = false ]; then
                empty_md=$((empty_md + 1))
                _feat_health="empty_claude_md"
                if [ "$fix_mode" = true ]; then
                    _create_claude_scaffold "$name" "$d/AGENTS.md"
                    _is_json || echo -e "  ${GREEN}Fixed:${NC} ${name} — created scaffold AGENTS.md (was 0 bytes)"
                    fixed=$((fixed + 1))
                    _feat_fixed=true
                else
                    _is_json || echo -e "  ${YELLOW}EMPTY${NC}   ${name} — AGENTS.md is 0 bytes"
                    issues=$((issues + 1))
                fi
            elif [ "$has_claude" = false ]; then
                missing_md=$((missing_md + 1))
                _feat_health="missing_claude_md"
                local artifacts=""
                [ "$has_session" = true ] && artifacts="${artifacts}session, "
                [ "$has_tasks" = true ] && artifacts="${artifacts}tasks, "
                artifacts="${artifacts%,*}"
                if [ "$fix_mode" = true ] && { [ "$has_session" = true ] || [ "$has_tasks" = true ]; }; then
                    _create_claude_scaffold "$name" "$d/AGENTS.md"
                    _is_json || echo -e "  ${GREEN}Fixed:${NC} ${name} — created scaffold AGENTS.md (had: ${artifacts})"
                    fixed=$((fixed + 1))
                    _feat_fixed=true
                else
                    _is_json || echo -e "  ${RED}LOST${NC}    ${name} — no AGENTS.md (has: ${artifacts})"
                    issues=$((issues + 1))
                fi
                if [ "$has_session" = true ]; then
                    orphaned_sessions=$((orphaned_sessions + 1))
                fi
                if [ "$has_tasks" = true ]; then
                    orphaned_tasks=$((orphaned_tasks + 1))
                fi
            fi

            # Collect for JSON
            [ "$_json_first" = true ] && _json_first=false || _json_features+=","
            _json_features+="{\"name\":\"$name\",\"health\":\"$_feat_health\",\"fixed\":$_feat_fixed}"
        done

        _is_json || echo ""
        _is_json || echo -e "  ${BOLD}Summary:${NC} ${total} features total"
        _is_json || echo -e "    ${GREEN}Healthy:${NC}         ${healthy}"
        if [ "$missing_md" -gt 0 ]; then
            _is_json || echo -e "    ${RED}Missing AGENTS.md:${NC} ${missing_md}"
        fi
        if [ "$empty_md" -gt 0 ]; then
            _is_json || echo -e "    ${YELLOW}Empty AGENTS.md:${NC}   ${empty_md}"
        fi
        _is_json || echo ""
    fi

    # 3. Check for empty feature dirs (no artifacts at all)
    local empty_dirs=0
    if [ -d "$FEATURES_DIR" ]; then
        for d in "$FEATURES_DIR"/*/; do
            [ -d "$d" ] || continue
            local name="$(basename "$d")"
            [ "$name" = "archived" ] && continue
            local contents
            contents=$(ls -A "$d" 2>/dev/null)
            if [ -z "$contents" ]; then
                if ! _is_json && [ "$empty_dirs" -eq 0 ]; then
                    echo -e "${BOLD}Empty Feature Dirs (no artifacts)${NC}"
                fi
                _is_json || echo -e "  ${YELLOW}${name}${NC} — completely empty directory"
                empty_dirs=$((empty_dirs + 1))
            fi
        done
        if [ "$empty_dirs" -gt 0 ]; then
            _is_json || echo ""
        fi
    fi

    # 4. Worktree health checks
    local wt_orphans=0
    local wt_stale=0
    local wt_header_shown=false
    if [ -d "$FEATURES_DIR" ]; then
        for d in "$FEATURES_DIR"/*/; do
            [ -d "$d" ] || continue
            local name="$(basename "$d")"
            [ "$name" = "archived" ] && continue
            if [ -f "$d/worktree" ]; then
                local wt_path
                wt_path="$(cat "$d/worktree")"
                if [ ! -d "$wt_path" ]; then
                    wt_orphans=$((wt_orphans + 1))
                    issues=$((issues + 1))
                    if ! _is_json; then
                        if [ "$wt_header_shown" = false ]; then
                            echo -e "${BOLD}Worktree Health${NC}"
                            wt_header_shown=true
                        fi
                        echo -e "  ${RED}ORPHAN${NC}  ${name} — worktree marker points to missing dir: ${wt_path}"
                    fi
                    if [ "$fix_mode" = true ]; then
                        rm -f "$d/worktree"
                        _is_json || echo -e "  ${GREEN}Fixed:${NC} removed orphaned worktree marker for '${name}'"
                        fixed=$((fixed + 1))
                    fi
                fi
            fi
        done
    fi
    # Check for stale worktree dirs not tracked by any feature
    if [ -d "$WORKTREES_DIR" ]; then
        for wt_dir in "$WORKTREES_DIR"/*/; do
            [ -d "$wt_dir" ] || continue
            local wt_name="$(basename "$wt_dir")"
            if [ ! -f "$FEATURES_DIR/$wt_name/worktree" ] && [ ! -f "$FEATURES_DIR/archived/$wt_name/worktree" ]; then
                wt_stale=$((wt_stale + 1))
                issues=$((issues + 1))
                if ! _is_json; then
                    if [ "$wt_header_shown" = false ]; then
                        echo -e "${BOLD}Worktree Health${NC}"
                        wt_header_shown=true
                    fi
                    echo -e "  ${YELLOW}STALE${NC}   ${wt_name} — worktree dir exists but no feature tracks it"
                fi
                if [ "$fix_mode" = true ]; then
                    local branch_name="worktree-$wt_name"
                    git worktree remove --force "$wt_dir" 2>/dev/null || rm -rf "$wt_dir"
                    git branch -D "$branch_name" >/dev/null 2>&1 || true
                    _is_json || echo -e "  ${GREEN}Fixed:${NC} removed stale worktree dir and branch for '${wt_name}'"
                    fixed=$((fixed + 1))
                fi
            fi
        done
    fi
    if [ "$wt_header_shown" = true ]; then
        _is_json || echo ""
    fi

    _json_features+="]"

    # JSON output
    if _is_json; then
        local _total=${total:-0}
        local _healthy=${healthy:-0}
        local _missing=${missing_md:-0}
        local _empty=${empty_md:-0}
        _json_emit "success" "@bool:true" "command" "doctor" \
            "fix_mode" "@bool:$fix_mode" \
            "features" "@json:$_json_features" \
            "summary" "@json:{\"total\":$_total,\"healthy\":$_healthy,\"missing_md\":$_missing,\"empty_md\":$_empty,\"fixed\":$fixed,\"wt_orphans\":${wt_orphans:-0},\"wt_stale\":${wt_stale:-0}}" \
            "issues" "@int:$issues"
        return
    fi

    # 4. Final verdict
    echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    if [ "$fix_mode" = true ]; then
        if [ "$fixed" -gt 0 ]; then
            echo -e "${GREEN}Fixed ${fixed} feature(s).${NC} Run ${CYAN}cody-switch doctor${NC} to verify."
        elif [ "$issues" -eq 0 ]; then
            echo -e "${GREEN}Nothing to fix — all features look healthy.${NC}"
        else
            echo -e "${YELLOW}${issues} issue(s) remain that could not be auto-fixed.${NC}"
        fi
    elif [ "$issues" -eq 0 ]; then
        echo -e "${GREEN}All features look healthy.${NC}"
    else
        echo -e "${RED}${issues} issue(s) detected.${NC}"
        echo ""
        echo -e "${YELLOW}To auto-fix empty/missing AGENTS.md files:${NC}"
        echo -e "  ${CYAN}cody-switch doctor --fix${NC}"
        echo ""
        echo -e "${YELLOW}Or manually:${NC}"
        echo -e "  1. Switch to it: ${CYAN}cody-switch <name>${NC} (a scaffold will be created)"
        echo -e "  2. Manually create the file: ${CYAN}echo '# Feature: <name>' > .codex/features/<name>/AGENTS.md${NC}"
        echo -e "  3. Delete the orphaned feature: ${CYAN}cody-switch delete <name>${NC}"
    fi
}

