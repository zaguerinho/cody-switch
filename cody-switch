# Detect tech stack from marker files at project root
_detect_stack() {
    if [ -f "$PROJECT_DIR/go.mod" ]; then
        echo "go"
    elif [ -f "$PROJECT_DIR/Cargo.toml" ]; then
        echo "rust"
    elif [ -f "$PROJECT_DIR/pyproject.toml" ] || [ -f "$PROJECT_DIR/setup.py" ] || [ -f "$PROJECT_DIR/requirements.txt" ]; then
        echo "python"
    elif [ -f "$PROJECT_DIR/package.json" ] && [ -f "$PROJECT_DIR/tsconfig.json" ]; then
        echo "typescript"
    elif [ -f "$PROJECT_DIR/package.json" ]; then
        echo "node"
    elif [ -f "$PROJECT_DIR/build.gradle" ] || [ -f "$PROJECT_DIR/pom.xml" ]; then
        echo "java"
    elif [ -f "$PROJECT_DIR/Gemfile" ]; then
        echo "ruby"
    elif [ -f "$PROJECT_DIR/composer.json" ]; then
        echo "php"
    elif [ -f "$PROJECT_DIR/CMakeLists.txt" ]; then
        echo "c-cpp"
    elif [ -f "$PROJECT_DIR/Makefile" ]; then
        echo "make"
    else
        echo "generic"
    fi
}

# Detect test framework from marker files
_detect_test_framework() {
    # JS/TS frameworks
    if ls "$PROJECT_DIR"/jest.config.* 1>/dev/null 2>&1 || \
       ([ -f "$PROJECT_DIR/package.json" ] && grep -q '"jest"' "$PROJECT_DIR/package.json" 2>/dev/null); then
        echo "jest"
    elif ls "$PROJECT_DIR"/vitest.config.* 1>/dev/null 2>&1 || \
         ([ -f "$PROJECT_DIR/package.json" ] && grep -q '"vitest"' "$PROJECT_DIR/package.json" 2>/dev/null); then
        echo "vitest"
    # Python
    elif [ -f "$PROJECT_DIR/conftest.py" ] || \
         ([ -f "$PROJECT_DIR/pyproject.toml" ] && grep -q '\[tool\.pytest' "$PROJECT_DIR/pyproject.toml" 2>/dev/null); then
        echo "pytest"
    # Go (native)
    elif [ -f "$PROJECT_DIR/go.mod" ]; then
        echo "go-test"
    # Bash
    elif ls "$PROJECT_DIR"/test/*.bats 1>/dev/null 2>&1; then
        echo "bats"
    # Ruby
    elif [ -f "$PROJECT_DIR/.rspec" ] || [ -d "$PROJECT_DIR/spec" ]; then
        echo "rspec"
    # PHP
    elif [ -f "$PROJECT_DIR/phpunit.xml" ]; then
        echo "phpunit"
    # Rust (native)
    elif [ -f "$PROJECT_DIR/Cargo.toml" ]; then
        echo "cargo-test"
    else
        echo "none"
    fi
}

# Detect build tool / package manager
_detect_build_tool() {
    local stack="$1"
    case "$stack" in
        node|typescript)
            if [ -f "$PROJECT_DIR/pnpm-lock.yaml" ]; then echo "pnpm"
            elif [ -f "$PROJECT_DIR/yarn.lock" ]; then echo "yarn"
            else echo "npm"
            fi
            ;;
        python)
            if [ -f "$PROJECT_DIR/uv.lock" ]; then echo "uv"
            elif [ -f "$PROJECT_DIR/poetry.lock" ]; then echo "poetry"
            elif [ -f "$PROJECT_DIR/Pipfile" ]; then echo "pipenv"
            else echo "pip"
            fi
            ;;
        go)         echo "go build" ;;
        rust)       echo "cargo" ;;
        java)
            if [ -f "$PROJECT_DIR/build.gradle" ]; then echo "gradle"
            else echo "maven"
            fi
            ;;
        ruby)       echo "bundler" ;;
        php)        echo "composer" ;;
        c-cpp)      echo "cmake" ;;
        make)       echo "make" ;;
        *)          echo "—" ;;
    esac
}

# Generate testing section for AGENTS.md based on detected framework
