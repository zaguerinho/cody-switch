            ;;
        pytest)
            cat << 'EOF'
Run `pytest`. Tests in `tests/`. Use fixtures over setUp.
EOF
            ;;
        go-test)
            cat << 'EOF'
Run `go test ./...`. Tests in `*_test.go`. Table-driven tests preferred.
EOF
            ;;
        bats)
            cat << 'EOF'
Run `bats test/`. Shellcheck must pass.
EOF
            ;;
        rspec)
