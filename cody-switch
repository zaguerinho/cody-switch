# Helper: install a single skill from source to ~/.codex/skills/{name}/
# Args: name, source_file, force_flag, label_prefix
_install_one_skill() {
    local name="$1" source="$2" force="$3" label="${4:-Skill}"
    local target="$CODEX_SKILLS_DIR/$name/SKILL.md"
    if [ ! -f "$target" ]; then
        mkdir -p "$CODEX_SKILLS_DIR/$name"
        cp "$source" "$target"
        echo -e "${GREEN}Installed ${label}: ${name}${NC}"
    elif diff -q "$source" "$target" >/dev/null 2>&1; then
        echo -e "${GREEN}${label} already installed: ${name}${NC}"
    elif [ "$force" = "--force" ]; then
        local backup="${target}.backup.$(date +%Y%m%d-%H%M%S)"
        cp "$target" "$backup"
        cp "$source" "$target"
        echo -e "${YELLOW}Updated ${label}: ${name} (backed up)${NC}"
    else
        echo -e "${YELLOW}${label} ${name} differs, use --force to update${NC}"
    fi
}

# Install a companion binary for a skill (downloaded from GitHub Releases).
# Looks for a BINARY metadata file in the skill's source directory.
_install_skill_binary() {
    local skill_dir="$1" force="$2"
    local binary_file="$skill_dir/BINARY"
    [ -f "$binary_file" ] || return 0  # No binary needed for this skill

    # Parse BINARY metadata
    local bin_name repo tag_prefix
    bin_name=$(grep '^name=' "$binary_file" | cut -d= -f2)
    repo=$(grep '^repo=' "$binary_file" | cut -d= -f2)
    tag_prefix=$(grep '^tag_prefix=' "$binary_file" | cut -d= -f2)

    [ -n "$bin_name" ] || return 0

    local target="$CODEX_BIN_DIR/$bin_name"

    # Skip if already installed and not --force
    if [ -x "$target" ] && [ "$force" != "--force" ]; then
        local cur_ver
        cur_ver=$("$target" --version 2>/dev/null | head -1)
        echo -e "${GREEN}Binary already installed: ${bin_name} ${cur_ver:+(${cur_ver})}${NC}"
        return 0
    fi

    # Detect platform
    local os arch
    os=$(uname -s | tr '[:upper:]' '[:lower:]')
    arch=$(uname -m)
    case "$arch" in
        x86_64)         arch="amd64" ;;
        aarch64|arm64)  arch="arm64" ;;
    esac

    # Get latest release tag matching prefix (uses gh for auth — works with private repos)
    local tag
    if command -v gh >/dev/null 2>&1; then
        tag=$(gh release list --repo "$repo" --json tagName -q '.[].tagName' 2>/dev/null \
            | grep "^${tag_prefix}" | head -1)
    fi

    if [ -z "$tag" ]; then
        echo -e "${YELLOW}No release found for ${bin_name}, skipping binary download${NC}"
        echo -e "${YELLOW}  Build from source: cd $SCRIPT_DIR/$bin_name && make build${NC}"
        return 0
    fi

    local version="${tag#$tag_prefix}"
    local archive="${bin_name}_${version}_${os}_${arch}.tar.gz"

    echo -e "Downloading ${CYAN}${bin_name}${NC} v${version} (${os}/${arch})..."

    # Download and extract to ~/.codex/bin/ (gh handles auth for private repos)
    local tmpdir
    tmpdir=$(mktemp -d)
    if gh release download "$tag" --repo "$repo" --pattern "$archive" --dir "$tmpdir" 2>/dev/null \
        && [ -s "$tmpdir/$archive" ]; then
        tar -xzf "$tmpdir/$archive" -C "$tmpdir" 2>/dev/null
        mkdir -p "$CODEX_BIN_DIR"
        mv "$tmpdir/$bin_name" "$target"
        chmod +x "$target"
        rm -rf "$tmpdir"

        # Verify
        if "$target" --version >/dev/null 2>&1; then
            echo -e "${GREEN}Installed binary: ${bin_name} v${version}${NC}"
        else
            echo -e "${GREEN}Installed binary: ${bin_name} (version check skipped)${NC}"
        fi

        # Hint: add ~/.codex/bin to PATH if not already there
        if ! echo "$PATH" | tr ':' '\n' | grep -q "$CODEX_BIN_DIR"; then
            echo -e "${YELLOW}  Add to your PATH: export PATH=\"\$HOME/.codex/bin:\$PATH\"${NC}"
            echo -e "${YELLOW}  Or add that line to your ~/.zshrc or ~/.bashrc${NC}"
        fi
    else
        rm -rf "$tmpdir"
        echo -e "${YELLOW}Download failed for ${bin_name} v${version} (${os}/${arch})${NC}"
        echo -e "${YELLOW}  Build from source: cd $SCRIPT_DIR/$bin_name && make build${NC}"
    fi
}

# Install cody-switch: create symlink, seed ~/AGENTS.md, and install skills.
install_cody_switch() {
    local force=""
    local install_extras=""
    local install_skill=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --force)    force="--force" ;;
            --extras)   install_extras="1" ;;
            --skill)    shift; install_skill="${1:-}" ;;
            --skill=*)  install_skill="${1#--skill=}" ;;
            *)          echo -e "${RED}Unknown install option: $1${NC}" >&2; return 1 ;;
        esac
        shift
    done

    echo -e "${BOLD}Installing cody-switch...${NC}"
    echo ""

    _install_cody_switch_symlink "$force" || return 1

    local pending_template="$HOME/AGENTS.md.template-pending"
    if [ -f "$GLOBAL_AGENTS_MD" ] && [ -s "$GLOBAL_AGENTS_MD" ]; then
        if [ "$force" = "--force" ]; then
            local backup="$HOME/AGENTS.md.backup.$(date +%Y%m%d-%H%M%S)"
            cp "$GLOBAL_AGENTS_MD" "$backup"
            echo -e "${BLUE}Backed up existing AGENTS.md to ${backup}${NC}"
            cp "$GLOBAL_TEMPLATE" "$GLOBAL_AGENTS_MD"
            echo -e "${GREEN}Seeded ~/AGENTS.md from template${NC}"
        elif diff -q "$GLOBAL_TEMPLATE" "$GLOBAL_AGENTS_MD" >/dev/null 2>&1; then
            echo -e "${GREEN}~/AGENTS.md is up to date${NC}"
        else
            cp "$GLOBAL_TEMPLATE" "$pending_template"
            echo -e "${YELLOW}~/AGENTS.md already exists with custom content${NC}"
            echo -e "Template saved to ${CYAN}~/AGENTS.md.template-pending${NC}"
            echo -e "Review with: ${CYAN}diff -u ~/AGENTS.md ~/AGENTS.md.template-pending${NC}"
        fi
    else
        cp "$GLOBAL_TEMPLATE" "$GLOBAL_AGENTS_MD"
        echo -e "${GREEN}Created global AGENTS.md at ${GLOBAL_AGENTS_MD}${NC}"
    fi

    local comp_source="$SCRIPT_DIR/completions/cody-switch.sh"
    if [ -f "$comp_source" ]; then
        local zsh_comp_dir="$HOME/.zsh/completions"
        mkdir -p "$zsh_comp_dir"
        cp "$comp_source" "$zsh_comp_dir/_cody-switch"

        if [ -f "$HOME/.zshrc" ] && ! grep -q 'fpath=.*\.zsh/completions' "$HOME/.zshrc" 2>/dev/null; then
            python3 -c "
import re

with open('$HOME/.zshrc') as f:
    content = f.read()

fpath_line = 'fpath=(~/.zsh/completions \$fpath)'

if re.search(r'source.*oh-my-zsh\.sh', content):
    content = re.sub(r'(source.*oh-my-zsh\.sh)', fpath_line + r'\n\1', content, count=1)
elif re.search(r'compinit', content):
    content = re.sub(r'(.*compinit)', fpath_line + r'\n\1', content, count=1)
else:
    content += '\n' + fpath_line + '\nautoload -Uz compinit && compinit\n'

with open('$HOME/.zshrc', 'w') as f:
    f.write(content)
" 2>/dev/null || true
        fi

        rm -f "$HOME"/.zcompdump*
        echo -e "${GREEN}Installed tab completions to ${zsh_comp_dir}/_cody-switch${NC}"
    fi

    if [ -d "$GLOBAL_SKILLS_DIR" ]; then
        local skill_dirs=("$GLOBAL_SKILLS_DIR"/*)
        for skill_dir in "${skill_dirs[@]}"; do
            [ -d "$skill_dir" ] || continue
            local skill_file="$skill_dir/SKILL.md"
            [ -f "$skill_file" ] || continue
            _install_one_skill "$(basename "$skill_dir")" "$skill_file" "$force"
            _install_skill_binary "$skill_dir" "$force"
        done
    fi

    if [ -n "$install_skill" ]; then
        local extra_dir="$GLOBAL_SKILLS_EXTRA_DIR/$install_skill"
        local extra_file="$extra_dir/SKILL.md"
        if [ ! -f "$extra_file" ]; then
            echo -e "${RED}Error: Extra skill '${install_skill}' not found${NC}" >&2
            if [ -d "$GLOBAL_SKILLS_EXTRA_DIR" ]; then
                echo -e "Available extras:" >&2
                for d in "$GLOBAL_SKILLS_EXTRA_DIR"/*/; do
                    [ -d "$d" ] && [ -f "$d/SKILL.md" ] && echo "  $(basename "$d")" >&2
                done
            fi
            return 1
        fi
        _install_one_skill "$install_skill" "$extra_file" "$force" "Extra skill"
        _install_skill_binary "$extra_dir" "$force"
    elif [ -n "$install_extras" ] && [ -d "$GLOBAL_SKILLS_EXTRA_DIR" ]; then
        echo ""
        echo -e "${BOLD}Installing extra skills...${NC}"
        for skill_dir in "$GLOBAL_SKILLS_EXTRA_DIR"/*/; do
            [ -d "$skill_dir" ] || continue
            local skill_file="$skill_dir/SKILL.md"
            [ -f "$skill_file" ] || continue
            _install_one_skill "$(basename "$skill_dir")" "$skill_file" "$force" "Extra skill"
            _install_skill_binary "$skill_dir" "$force"
        done
    fi

    echo ""
    echo -e "${YELLOW}Codex note:${NC} there is no Claude-style SessionStart hook or slash-command install path."
    echo -e "Use ${CYAN}cody-switch current${NC} after a switch, and use ${CYAN}cody-switch prompt list${NC} for the bundled prompt templates."
    echo ""
    echo -e "${GREEN}Installation complete!${NC}"
    echo -e "Verify: ${CYAN}cody-switch help${NC}"
}

uninstall_cody_switch() {
    echo -e "${BOLD}Uninstalling cody-switch...${NC}"
    echo ""

    _remove_symlink_path "$SYMLINK_PATH" "system" true
    _remove_symlink_path "$USER_SYMLINK_PATH" "user" false

    if [ -f "$GLOBAL_AGENTS_MD" ]; then
        echo -e "${BLUE}Kept global config at ${GLOBAL_AGENTS_MD}${NC}"
    fi

    local zsh_comp="$HOME/.zsh/completions/_cody-switch"
    if [ -f "$zsh_comp" ]; then
        rm "$zsh_comp"
        echo -e "${GREEN}Removed tab completions: ${zsh_comp}${NC}"
    fi

    for _skills_source_dir in "$GLOBAL_SKILLS_DIR" "$GLOBAL_SKILLS_EXTRA_DIR"; do
        [ -d "$_skills_source_dir" ] || continue
        for skill_dir in "$_skills_source_dir"/*/; do
            [ -d "$skill_dir" ] || continue
            local skill_file="$skill_dir/SKILL.md"
            [ -f "$skill_file" ] || continue
            local skill_name
            skill_name="$(basename "$skill_dir")"
            local target="$CODEX_SKILLS_DIR/$skill_name/SKILL.md"
            if [ ! -f "$target" ]; then
                continue
            elif diff -q "$skill_file" "$target" >/dev/null 2>&1; then
                rm "$target"
                rmdir "$CODEX_SKILLS_DIR/$skill_name" 2>/dev/null || true
                echo -e "${GREEN}Removed skill: ${skill_name}${NC}"
            else
                echo -e "${YELLOW}Kept modified skill: ${skill_name}${NC}"
            fi

            local binary_meta="$skill_dir/BINARY"
            if [ -f "$binary_meta" ]; then
                local bin_name
                bin_name=$(grep '^name=' "$binary_meta" | cut -d= -f2)
                if [ -n "$bin_name" ] && [ -f "$CODEX_BIN_DIR/$bin_name" ]; then
                    rm "$CODEX_BIN_DIR/$bin_name"
                    echo -e "${GREEN}Removed binary: ${bin_name}${NC}"
                fi
            fi
        done
    done

    echo ""
    echo -e "${GREEN}Uninstall complete!${NC}"
}

update_cody_switch() {
    echo -e "${BOLD}Updating cody-switch...${NC}"
    echo ""

    local old_version="$VERSION"
    if ! git -C "$SCRIPT_DIR" pull --ff-only; then
        echo -e "${RED}Error: Failed to pull updates. You may have local changes in ${SCRIPT_DIR}${NC}" >&2
        echo -e "Resolve conflicts manually, then retry.${NC}" >&2
        exit 1
    fi

    local new_version
    new_version="$(grep -m1 '^VERSION=' "$REAL_SCRIPT" | cut -d'"' -f2)"

    echo ""
    if [ "$old_version" = "$new_version" ]; then
        echo -e "${GREEN}Already up to date (v${old_version}).${NC}"
    else
        echo -e "${GREEN}Updated: v${old_version} → v${new_version}${NC}"
    fi

    echo -e "${CYAN}Tip: Run 'cody-switch install --force' to refresh ~/AGENTS.md and installed skills.${NC}"
}

show_prompt_template() {
    local name="$1"
    if [ -z "$name" ] || [ "$name" = "list" ]; then
        echo "Available prompt templates:"
        for prompt_file in "$PROMPT_TEMPLATES_DIR"/*.md; do
            [ -f "$prompt_file" ] || continue
            basename "$prompt_file" .md | sed 's/^/  /'
        done
        return 0
    fi

    local prompt_file="$PROMPT_TEMPLATES_DIR/$name.md"
    if [ ! -f "$prompt_file" ]; then
        echo -e "${RED}Error: Prompt template '${name}' not found${NC}" >&2
        echo "Use 'cody-switch prompt list' to see available templates." >&2
        return 1
    fi

    cat "$prompt_file"
}

case "${1:-}" in
    install)    shift; install_cody_switch "$@"; exit 0 ;;
    uninstall)  uninstall_cody_switch; exit 0 ;;
    update)     update_cody_switch; exit 0 ;;
    prompt)     shift; show_prompt_template "$@"; exit $? ;;
    help|-h|--help) show_help; exit 0 ;;
    --version|-V) echo "cody-switch v${VERSION}"; exit 0 ;;
esac

# Output format: "text" (default) or "json"
OUTPUT_FORMAT="text"
_global_args=()
for _arg in "$@"; do
    case "$_arg" in
        --output=json|--json) OUTPUT_FORMAT="json" ;;
        --output=text)        OUTPUT_FORMAT="text" ;;
        *) _global_args+=("$_arg") ;;
    esac
done
set -- "${_global_args[@]}"

# JSON output helpers
_is_json() { [ "$OUTPUT_FORMAT" = "json" ]; }

_json_emit() {
    python3 -c "
import sys, json
args = sys.argv[1:]
obj = {}
i = 0
while i < len(args):
    key = args[i]
    val = args[i+1] if i+1 < len(args) else ''
    if val.startswith('@bool:'):
        obj[key] = val[6:] == 'true'
    elif val.startswith('@int:'):
        obj[key] = int(val[5:])
    elif val.startswith('@array:'):
        items = val[7:].split('\n') if val[7:] else []
        obj[key] = [x for x in items if x]
    elif val.startswith('@json:'):
        obj[key] = json.loads(val[6:])
    elif val == '@null':
        obj[key] = None
    else:
        obj[key] = val
    i += 2
print(json.dumps(obj, indent=2))
" "$@"
}

_json_error() {
    _json_emit "success" "@bool:false" "error" "$1"
    exit "${2:-1}"
}

# Detect project root: walk up from cwd to find the nearest git root
# Handles both regular repos (.git is a directory) and git worktrees (.git is a file)
find_project_root() {
    local dir="$PWD"
    while [ "$dir" != "/" ]; do
        if [ -d "$dir/.git" ]; then
            echo "$dir"
            return 0
        elif [ -f "$dir/.git" ]; then
            # Inside a git worktree — .git is a file pointing to the main repo
            # Resolve to the main repo root via the shared git directory
            local git_common_dir
            git_common_dir="$(cd "$dir" && git rev-parse --git-common-dir 2>/dev/null)"
            if [ -n "$git_common_dir" ]; then
                # git-common-dir returns the shared .git dir (e.g., /repo/.git)
                # The main repo root is its parent
                local main_root
                main_root="$(cd "$dir" && cd "$git_common_dir/.." && pwd)"
                echo "$main_root"
                return 0
            fi
            # No fallback — if we're in a worktree but can't resolve the main repo, fail loudly
            echo -e "${RED}Error: Inside a git worktree but could not resolve main repo root${NC}" >&2
            return 1
        fi
        dir="$(dirname "$dir")"
    done
    return 1
}

PROJECT_DIR="$(find_project_root)" || {
    echo -e "${RED}Error: Not inside a git repository. Run cody-switch from within a project.${NC}" >&2
    exit 1
}

TRACKER_FILE="$PROJECT_DIR/.codex-current-feature"
CLAUDE_MD="$PROJECT_DIR/AGENTS.md"
WORKFLOW_TEMPLATE="$SCRIPT_DIR/workflow.md"
DOCS_DIR="$PROJECT_DIR/docs"
TASKS_DIR="$PROJECT_DIR/tasks"
FEATURES_DIR="$PROJECT_DIR/.codex/features"
WITH_REFS_FILE="$PROJECT_DIR/.codex-with-refs"
WORKTREES_DIR="$PROJECT_DIR/.codex/worktrees"

cd "$PROJECT_DIR"

# Validate a feature name is safe for use in file paths and git refs
# Rejects: empty, contains '/', contains '..', starts with '-'
_validate_feature_name() {
    local name="$1"
    if [ -z "$name" ] || [[ "$name" == -* ]] || [[ "$name" == */* ]] || [[ "$name" == *..* ]]; then
        _is_json && _json_error "Invalid feature name '${name}': cannot contain '/', '..', or start with '-'"
        echo -e "${RED}Error: Invalid feature name '${name}'${NC}" >&2
        echo "Names cannot contain '/', '..', or start with '-'." >&2
        exit 1
    fi
}

# Get the feature storage directory for a feature name
get_feature_dir() {
    _validate_feature_name "$1"
    echo "$FEATURES_DIR/$1"
}

# Get the archived feature storage directory for a feature name
get_archived_feature_dir() {
    _validate_feature_name "$1"
    echo "$FEATURES_DIR/archived/$1"
}

# Ensure feature directory exists
ensure_feature_dir() {
    mkdir -p "$(get_feature_dir "$1")"
}

# Migrate legacy layout (AGENTS.md.*, tasks.*, .claude-session-*) to .codex/features/
migrate_legacy_layout() {
    local migrated=false

    # Migrate active features: AGENTS.md.{name} (excluding archived)
    for f in AGENTS.md.*; do
        [ -f "$f" ] || continue
        local name="${f#AGENTS.md.}"
        # Skip archived files (handled below)
        case "$name" in archived.*) continue ;; esac
        local dest="$FEATURES_DIR/$name"
        mkdir -p "$dest"
        mv "$f" "$dest/AGENTS.md"
        migrated=true
    done

    # Migrate archived features: AGENTS.md.archived.{name}
    for f in AGENTS.md.archived.*; do
        [ -f "$f" ] || continue
        local name="${f#AGENTS.md.archived.}"
        local dest="$FEATURES_DIR/archived/$name"
        mkdir -p "$dest"
        mv "$f" "$dest/AGENTS.md"
        migrated=true
    done

    # Migrate active task dirs: tasks.{name}/ (excluding archived and tmp)
    for d in tasks.*; do
        [ -d "$d" ] || continue
        local name="${d#tasks.}"
        case "$name" in archived.*|*.tmp.*) continue ;; esac
        local dest="$FEATURES_DIR/$name"
        mkdir -p "$dest"
        if [ -d "$dest/tasks" ]; then
            local tmp="$dest/tasks.tmp.$$"
            mv "$dest/tasks" "$tmp"
            mv "$d" "$dest/tasks"
            rm -rf "$tmp"
        else
            mv "$d" "$dest/tasks"
        fi
        migrated=true
    done

    # Migrate archived task dirs: tasks.archived.{name}/
    for d in tasks.archived.*; do
        [ -d "$d" ] || continue
        local name="${d#tasks.archived.}"
        case "$name" in *.tmp.*) continue ;; esac
        local dest="$FEATURES_DIR/archived/$name"
        mkdir -p "$dest"
        if [ -d "$dest/tasks" ]; then
            local tmp="$dest/tasks.tmp.$$"
            mv "$dest/tasks" "$tmp"
            mv "$d" "$dest/tasks"
            rm -rf "$tmp"
        else
            mv "$d" "$dest/tasks"
        fi
        migrated=true
    done

    # Migrate session files: .claude-session-{name}
    for f in .claude-session-*; do
        [ -f "$f" ] || continue
        local name="${f#.claude-session-}"
        # Determine if this feature is archived or active
        if [ -d "$FEATURES_DIR/archived/$name" ]; then
            mv "$f" "$FEATURES_DIR/archived/$name/session"
        elif [ -d "$FEATURES_DIR/$name" ]; then
            mv "$f" "$FEATURES_DIR/$name/session"
        fi
        # If neither dir exists, the session file is orphaned — leave it
        migrated=true
    done

    if [ "$migrated" = true ]; then
        echo -e "${GREEN}Migrated legacy feature files to .codex/features/${NC}"
        echo -e "${YELLOW}Tip: Update your .gitignore to include .codex/features/ and .codex-last-seen-feature${NC}"
    fi
}

# Run migration (idempotent — skips if no legacy files exist)
migrate_legacy_layout

# Get current git branch
get_branch() {
    git branch --show-current 2>/dev/null || echo "(unknown)"
}

# Check for uncommitted changes
check_uncommitted() {
    if ! git diff --quiet 2>/dev/null || ! git diff --cached --quiet 2>/dev/null; then
        return 1  # Has uncommitted changes
    fi
    # Also check for untracked files (optional - uncomment if you want to include)
    # if [ -n "$(git ls-files --others --exclude-standard)" ]; then
    #     return 1
    # fi
    return 0  # Clean
}

# Get list of features (excludes archived)
# A feature is any directory that has AGENTS.md, session files, or tasks
get_features() {
    if [ -d "$FEATURES_DIR" ]; then
        for d in "$FEATURES_DIR"/*/; do
            [ -d "$d" ] || continue
            local name="$(basename "$d")"
            [ "$name" = "archived" ] && continue
            # A feature exists if it has ANY artifact (AGENTS.md, session, tasks)
            if [ -f "$d/AGENTS.md" ] || [ -f "$d/session" ] || [ -f "$d/session-latest" ] || [ -d "$d/tasks" ]; then
                echo "$name"
            fi
        done | sort
    fi
}

# Get list of archived features
get_archived_features() {
    if [ -d "$FEATURES_DIR/archived" ]; then
        for d in "$FEATURES_DIR/archived"/*/; do
            [ -d "$d" ] || continue
            local name="$(basename "$d")"
            if [ -f "$d/AGENTS.md" ] || [ -f "$d/session" ] || [ -f "$d/session-latest" ] || [ -d "$d/tasks" ]; then
                echo "$name"
            fi
        done | sort
    fi
}

# Get current feature
get_current() {
    if [ -f "$TRACKER_FILE" ]; then
        cat "$TRACKER_FILE"
    elif [ -f "$CLAUDE_MD" ]; then
        echo "(active but untracked)"
    else
        echo "(none)"
    fi
}

# Ensure docs folder exists for a feature
ensure_docs_folder() {
    local name="$1"
    local docs_path="$DOCS_DIR/$name"
    if [ ! -d "$docs_path" ]; then
        mkdir -p "$docs_path"
        _is_json || echo -e "${BLUE}Created docs folder: docs/${name}/${NC}"
    fi
}

# Save tasks/ folder for a feature (atomic via mv)
save_tasks() {
    local feature="$1"
    if [ -d "$TASKS_DIR" ]; then
        local feature_dir="$(get_feature_dir "$feature")"
        ensure_feature_dir "$feature"
        local saved="$feature_dir/tasks"
        # Sync root tasks/ to storage (copy, not move — keeps stored version for git)
        # Idempotent: skip if content is already identical (avoids dirty git state)
        if [ ! -d "$saved" ] || ! diff -rq "$TASKS_DIR" "$saved" >/dev/null 2>&1; then
            rm -rf "$saved"
            cp -R "$TASKS_DIR" "$saved"
        fi
        _is_json || echo -e "${BLUE}Saved tasks/ → ${feature}${NC}"
    else
        _is_json || echo -e "${YELLOW}Warning: No tasks/ directory found to save for '${feature}'${NC}"
    fi
}

# Restore tasks/ folder for a feature (copy from storage, not move — keeps stored version for git)
restore_tasks() {
    local feature="$1"
    local saved="$(get_feature_dir "$feature")/tasks"
    if [ -d "$saved" ]; then
        rm -rf "$TASKS_DIR"
        cp -R "$saved" "$TASKS_DIR"
        _is_json || echo -e "${BLUE}Restored tasks/ for ${feature}${NC}"
    else
        _is_json || echo -e "${YELLOW}No saved tasks found for '${feature}', creating fresh scaffold${NC}"
        create_fresh_tasks
    fi
}

# Untrack workspace files that git is still tracking despite .gitignore.
# This happens when files were committed before their .gitignore entries were added.
# Git's .gitignore only prevents NEW files from being tracked; already-tracked
# files continue to show up in diffs and commits — causing silent overwrites
# when feature-switching replaces their content.
_untrack_gitignored_workspace() {
    local to_untrack=()
    for path in "tasks" "AGENTS.md" ".codex-current-feature" ".codex-last-seen-feature" ".codex-with-refs"; do
        # Use git check-ignore --no-index — handles all pattern variants (/tasks, tasks/, wildcards, global gitignore)
        # --no-index is required because these files ARE tracked (that's the bug we're fixing)
        git -C "$PROJECT_DIR" check-ignore --no-index -q "$path" 2>/dev/null || continue
        if [ -n "$(git -C "$PROJECT_DIR" ls-files --cached -- "$path" 2>/dev/null)" ]; then
            to_untrack+=("$path")
        fi
    done
    [ ${#to_untrack[@]} -eq 0 ] && return 0
    git -C "$PROJECT_DIR" rm --cached -rq -- "${to_untrack[@]}" >/dev/null 2>&1 || true
    _is_json || echo -e "${YELLOW}Untracked ${#to_untrack[@]} workspace path(s) from git index (committed before .gitignore)${NC}"
}

# Find the transcript file for a saved Codex session ID.
get_codex_session_file() {
    local session_id="$1"
    [ -n "$session_id" ] || return 1
    find "$HOME/.codex/sessions" -type f -name "*-${session_id}.jsonl" 2>/dev/null | head -1
}

_codex_session_matches_project() {
    local transcript="$1"
    grep -Fq "\"cwd\":\"$PROJECT_DIR\"" "$transcript" 2>/dev/null || \
        grep -Fq "\"cwd\":\"$PROJECT_DIR/" "$transcript" 2>/dev/null
}

# Get the most recent Codex session ID for this project. Prefer the live thread ID
# when cody-switch is running inside Codex, otherwise search the saved transcripts.
get_latest_session_id() {
    if [ -n "${CODEX_THREAD_ID:-}" ]; then
        local live_transcript
        live_transcript=$(get_codex_session_file "$CODEX_THREAD_ID" || true)
        if [ -z "$live_transcript" ] || _codex_session_matches_project "$live_transcript"; then
            echo "$CODEX_THREAD_ID"
            return 0
        fi
    fi

    [ -d "$HOME/.codex/sessions" ] || return 1

    local activated_at=""
    if [ -f "$TRACKER_FILE" ]; then
        activated_at=$(stat -f %m "$TRACKER_FILE" 2>/dev/null || stat -c %Y "$TRACKER_FILE" 2>/dev/null)
    fi

    local best_file=""
    local best_time=0
    while IFS= read -r transcript; do
        [ -f "$transcript" ] || continue
        local fmtime
        fmtime=$(stat -f %m "$transcript" 2>/dev/null || stat -c %Y "$transcript" 2>/dev/null)
        if [ -n "$activated_at" ] && [ "$fmtime" -lt "$activated_at" ]; then
            continue
        fi
        _codex_session_matches_project "$transcript" || continue
        if [ -z "$best_file" ] || [ "$fmtime" -gt "$best_time" ]; then
            best_file="$transcript"
            best_time="$fmtime"
        fi
    done < <(find "$HOME/.codex/sessions" -type f -name '*.jsonl' 2>/dev/null)

    [ -n "$best_file" ] || return 1
    basename "$best_file" .jsonl | sed -E 's/^.*-([0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12})$/\1/'
}

save_session() {
    local feature="$1"
    local session_id
    session_id=$(get_latest_session_id) || {
        _is_json || echo -e "${YELLOW}No Codex session found for '${feature}'${NC}"
        return 0
    }
    ensure_feature_dir "$feature"
    local fdir="$(get_feature_dir "$feature")"
    echo "$session_id" > "$fdir/session-latest"
    if [ ! -f "$fdir/session" ]; then
        echo "$session_id" > "$fdir/session"
    fi
    _is_json || echo -e "${BLUE}Saved Codex session ID for '${feature}'${NC}"
}

# Validate a saved session by checking that its transcript still exists and
# still belongs to this project.
_validate_session() {
    local session_id="$1"
    local source_file="$2"
    local feature="$3"

    local transcript
    transcript=$(get_codex_session_file "$session_id") || {
        rm -f "$source_file"
        return 1
    }

    if [ ! -f "$transcript" ]; then
        echo -e "${YELLOW}Session ${session_id:0:8}… for '${feature}' no longer exists${NC}"
        rm -f "$source_file"
        return 1
    fi

    if ! _codex_session_matches_project "$transcript"; then
        echo -e "${YELLOW}Session ${session_id:0:8}… for '${feature}' points to a different project${NC}"
        rm -f "$source_file"
        return 1
    fi

    return 0
}

# Restore (display) the Codex session resume commands for a feature (dual: checkpoint + latest)
restore_session() {
    local feature="$1"
    local fdir="$(get_feature_dir "$feature")"

    local checkpoint_file="$fdir/session"
    local latest_file="$fdir/session-latest"
    local summary_file="$fdir/session-summary"

    # Read and validate checkpoint
    local checkpoint_id=""
    if [ -f "$checkpoint_file" ]; then
        checkpoint_id=$(cat "$checkpoint_file")
        if [ -n "$checkpoint_id" ]; then
            _validate_session "$checkpoint_id" "$checkpoint_file" "$feature" || checkpoint_id=""
        fi
    fi

    # Read and validate latest
    local latest_id=""
    if [ -f "$latest_file" ]; then
        latest_id=$(cat "$latest_file")
        if [ -n "$latest_id" ]; then
            _validate_session "$latest_id" "$latest_file" "$feature" || latest_id=""
        fi
    fi

    # Nothing to show
    if [ -z "$checkpoint_id" ] && [ -z "$latest_id" ]; then
        return 0
    fi

    # Read summary if available
    local summary=""
    if [ -f "$summary_file" ]; then
        summary=$(cat "$summary_file")
    fi

    echo ""
    echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GREEN}Previous Codex session(s) for '${feature}'${NC}"
    echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

    if [ -n "$checkpoint_id" ] && [ -n "$latest_id" ] && [ "$checkpoint_id" != "$latest_id" ]; then
        echo ""
        echo -e "  ${YELLOW}Checkpoint (fork point):${NC}"
        if [ -n "$summary" ]; then
            echo -e "  ${BLUE}${summary}${NC}"
        fi
        echo -e "  ${CYAN}codex fork ${checkpoint_id}${NC}  ${GREEN}← recommended${NC}"
        echo ""
        echo -e "  ${YELLOW}Latest session:${NC}"
        echo -e "  ${CYAN}codex resume ${latest_id}${NC}"
        echo ""
    elif [ -n "$checkpoint_id" ]; then
        echo ""
        if [ -n "$summary" ]; then
            echo -e "  ${BLUE}${summary}${NC}"
            echo ""
        fi
        echo -e "  ${YELLOW}Resume with full context:${NC}"
        echo -e "  ${CYAN}codex resume ${checkpoint_id}${NC}"
        echo ""
        echo -e "  ${YELLOW}Or fork into a new session (recommended):${NC}"
        echo -e "  ${CYAN}codex fork ${checkpoint_id}${NC}"
        echo ""
    else
        echo ""
        echo -e "  ${YELLOW}Resume latest session:${NC}"
        echo -e "  ${CYAN}codex resume ${latest_id}${NC}"
        echo ""
    fi
}

# Pin the current session as a checkpoint with an optional summary
pin_session() {
    local current=$(get_current)
    if [ "$current" = "(none)" ] || [ "$current" = "(active but untracked)" ]; then
        _is_json && _json_error "No active feature to pin a session for"
        echo -e "${RED}Error: No active feature to pin a session for${NC}" >&2
        exit 1
    fi

    local session_id
    session_id=$(get_latest_session_id) || {
        _is_json && _json_error "No Codex session found for '${current}'"
        echo -e "${RED}Error: No Codex session found for '${current}'${NC}" >&2
        exit 1
    }

    local fdir="$(get_feature_dir "$current")"
    ensure_feature_dir "$current"

    local summary=""
    if _is_json; then
        # Skip interactive prompt in JSON mode
        :
    else
        echo -e "${BOLD}Pinning session for '${current}'${NC}"
        echo -e "Session: ${CYAN}${session_id}${NC}"
        echo ""
        echo -en "${YELLOW}One-sentence summary (Enter to skip):${NC} "
        read -r summary
    fi

    echo "$session_id" > "$fdir/session"
    if [ -n "$summary" ]; then
        echo "$summary" > "$fdir/session-summary"
    else
        rm -f "$fdir/session-summary"
    fi

    if _is_json; then
        _json_emit "success" "@bool:true" "command" "pin-session" \
            "feature" "$current" "session_id" "$session_id"
        return
    fi

    echo ""
    echo -e "${GREEN}Pinned checkpoint for '${current}'${NC}"
    if [ -n "$summary" ]; then
        echo -e "  ${BLUE}${summary}${NC}"
    fi
}

# Create fresh tasks/ scaffold
create_fresh_tasks() {
    local target="${1:-$TASKS_DIR}"
    mkdir -p "$target"
    if [ ! -f "$target/todo.md" ]; then
        cat > "$target/todo.md" << 'SCAFFOLD'
# TODO

## Plan

- [ ] ...

## Review

_(filled after implementation)_
SCAFFOLD
    fi
    if [ ! -f "$target/lessons.md" ]; then
        local global_lessons="$FEATURES_DIR/lessons-global.md"
        if [ -f "$global_lessons" ]; then
            cat > "$target/lessons.md" << SCAFFOLD
