}

# Initialize a project for AI-assisted development
init_project() {
    local template=""
    local force=false
    local prev_arg=""

    for arg in "$@"; do
        case "$arg" in
            --template=*) template="${arg#--template=}" ;;
            --template)   ;;
            --force)      force=true ;;
            *)
                if [ "$prev_arg" = "--template" ]; then
                    template="$arg"
                else
                    _is_json && _json_error "Unknown argument: $arg"
                    echo -e "${RED}Error: Unknown argument: $arg${NC}" >&2
                    echo "Usage: cody-switch init [--template <t>] [--force]" >&2
                    exit 1
                fi
                ;;
        esac
        prev_arg="$arg"
    done

    # Validate --template value if given
    local valid_templates="node typescript python go rust java ruby php c-cpp make generic"
    if [ -n "$template" ]; then
        local found=false
        for t in $valid_templates; do
            if [ "$template" = "$t" ]; then found=true; break; fi
        done
        if [ "$found" = false ]; then
            _is_json && _json_error "Unknown template '$template'"
            echo -e "${RED}Error: Unknown template '$template'${NC}" >&2
            echo -e "Valid templates: ${CYAN}${valid_templates}${NC}" >&2
            exit 1
        fi
    fi

    # Guard: already initialized?
    if [ -d "$FEATURES_DIR" ] && [ "$force" = false ]; then
        local count=0
        for d in "$FEATURES_DIR"/*/; do
            [ -d "$d" ] || continue
            local name
            name="$(basename "$d")"
            [ "$name" = "archived" ] && continue
            count=$((count + 1))
        done
        if [ "$count" -gt 0 ]; then
            if _is_json; then
                _json_emit "success" "@bool:false" "error" "Project already initialized ($count features)"
                return 0
            fi
            echo -e "${YELLOW}Project already initialized${NC} ($count features in .codex/features/)"
            echo -e "Use ${CYAN}--force${NC} to reinitialize"
            return 0
        fi
    fi

    # Guard: existing AGENTS.md?
    if [ -f "$CLAUDE_MD" ] && [ "$force" = false ]; then
        if _is_json; then
            _json_emit "success" "@bool:false" "error" "AGENTS.md already exists at project root"
            return 0
        fi
        echo -e "${YELLOW}AGENTS.md already exists at project root${NC}"
        echo -e "Use ${CYAN}--force${NC} to reinitialize (existing AGENTS.md will be backed up)"
        return 0
    fi

    # Backup existing AGENTS.md if --force
    if [ -f "$CLAUDE_MD" ] && [ "$force" = true ]; then
        local backup="$CLAUDE_MD.backup.$(date +%Y%m%d%H%M%S)"
        cp "$CLAUDE_MD" "$backup"
        _is_json || echo -e "  ${YELLOW}Backed up${NC} AGENTS.md → $(basename "$backup")"
    fi

    # Detect or use template
    local stack
    if [ -n "$template" ]; then
        stack="$template"
    else
        stack="$(_detect_stack)"
    fi
    local test_fw
    test_fw="$(_detect_test_framework)"
    local build_tool
    build_tool="$(_detect_build_tool "$stack")"
    local project_name
    project_name="$(basename "$PROJECT_DIR")"

    # Create .codex/features/
    mkdir -p "$FEATURES_DIR"

    # Generate AGENTS.md
    local testing_content
    testing_content="$(_testing_section "$test_fw")"

    cat > "$CLAUDE_MD" << INITEOF
# Project: ${project_name}

## Tech Stack

- **Language:** $(_stack_display_name "$stack")
- **Build:** ${build_tool}

## Testing

${testing_content}

## Key Files

<!-- Add important files and their purposes here -->

## Conventions

<!-- Add project-specific conventions here -->
INITEOF

    # .gitignore
    _init_gitignore

    if _is_json; then
        _json_emit "success" "@bool:true" "command" "init" \
            "project" "$project_name" \
            "stack" "$stack" \
            "test_framework" "$test_fw" \
            "build_tool" "$build_tool"
        return
    fi

    # Summary
    echo ""
    echo -e "${GREEN}${BOLD}Project initialized!${NC}"
    echo ""
    echo -e "  ${CYAN}Project:${NC}    ${project_name}"
    echo -e "  ${CYAN}Stack:${NC}      $(_stack_display_name "$stack")"
    if [ "$test_fw" != "none" ]; then
        echo -e "  ${CYAN}Testing:${NC}    ${test_fw}"
    fi
    echo ""
    echo -e "  ${BOLD}Created:${NC}"
    echo -e "  ${GREEN}.codex/features/${NC}    feature storage"
    echo -e "  ${GREEN}AGENTS.md${NC}             project context"

    echo ""
    echo -e "  ${BOLD}Next steps:${NC}"
    echo -e "  1. Edit ${CYAN}AGENTS.md${NC} with project-specific context"
    echo -e "  2. Start your first feature:"
    echo -e "     ${CYAN}cody-switch blank <feature-name>${NC}"
}

# Append content from one task file to another with a separator
_merge_task_file() {
    local src_file="$1"
    local dst_file="$2"
    local label="$3"

    # Nothing to merge if source doesn't exist or is empty
    [ -f "$src_file" ] && [ -s "$src_file" ] || return 0

    if [ -f "$dst_file" ] && [ -s "$dst_file" ]; then
        # Both exist: append with separator
        printf '\n\n---\n<!-- Merged from: %s -->\n\n' "$label" >> "$dst_file"
        cat "$src_file" >> "$dst_file"
    else
        # Target missing or empty: just copy
        mkdir -p "$(dirname "$dst_file")"
        cp "$src_file" "$dst_file"
    fi
}

# Merge one feature into another
merge_feature() {
    local source=""
    local target=""
    local delete_source=false
    local parsing_target=false

    # Parse args
    while [ $# -gt 0 ]; do
        case "$1" in
            into)
                parsing_target=true
                ;;
            --delete)
                delete_source=true
                ;;
            *)
                if [ "$parsing_target" = true ]; then
                    target="$1"
                    parsing_target=false
                elif [ -z "$source" ]; then
                    source="$1"
                fi
                ;;
        esac
        shift
    done

    if [ -z "$source" ]; then
        _is_json && _json_error "Please provide a source feature to merge"
        echo -e "${RED}Error: Please provide a source feature to merge${NC}" >&2
        echo "Usage: cody-switch merge <source> [into <target>] [--delete]" >&2
        exit 1
    fi

    if [ "$source" = "archived" ]; then
        _is_json && _json_error "'archived' is a reserved name"
        echo -e "${RED}Error: 'archived' is a reserved name${NC}" >&2
        exit 1
    fi

    # Default target to current active feature
    local current
    current=$(get_current)
    if [ -z "$target" ]; then
        if [ "$current" = "(none)" ] || [ "$current" = "(active but untracked)" ]; then
            _is_json && _json_error "No active feature. Specify a target with 'into <target>'"
            echo -e "${RED}Error: No active feature. Specify a target with 'into <target>'${NC}" >&2
            exit 1
        fi
        target="$current"
    fi

    if [ "$target" = "archived" ]; then
        _is_json && _json_error "'archived' is a reserved name"
        echo -e "${RED}Error: 'archived' is a reserved name${NC}" >&2
        exit 1
    fi

    # Block: source = target
    if [ "$source" = "$target" ]; then
        _is_json && _json_error "Cannot merge a feature into itself"
        echo -e "${RED}Error: Cannot merge a feature into itself${NC}" >&2
        exit 1
    fi

    # Block: source is active
    if [ "$current" = "$source" ]; then
        _is_json && _json_error "Cannot merge the active feature '${source}'"
        echo -e "${RED}Error: Cannot merge the active feature '${source}'${NC}" >&2
        echo "Switch to another feature first." >&2
        exit 1
    fi

    # Resolve source dir (stored or archived)
    local source_dir=""
    local source_archived=false
    if [ -d "$(get_feature_dir "$source")" ]; then
        source_dir="$(get_feature_dir "$source")"
    elif [ -d "$(get_archived_feature_dir "$source")" ]; then
        source_dir="$(get_archived_feature_dir "$source")"
        source_archived=true
    else
        _is_json && _json_error "Feature '${source}' not found"
        echo -e "${RED}Error: Feature '${source}' not found${NC}" >&2
        exit 1
    fi

    # Sync worktree state before merging (get latest content)
    if is_worktree_feature "$source"; then
        sync_from_worktree "$source"
    fi

    # Resolve target dir and check it's not archived
    local target_dir=""
    local target_is_active=false
    if [ "$target" = "$current" ]; then
        target_is_active=true
    elif [ -d "$(get_feature_dir "$target")" ]; then
        target_dir="$(get_feature_dir "$target")"
    elif [ -d "$(get_archived_feature_dir "$target")" ]; then
        _is_json && _json_error "Target '${target}' is archived. Unarchive it first."
        echo -e "${RED}Error: Target '${target}' is archived. Unarchive it first.${NC}" >&2
        exit 1
    else
        _is_json && _json_error "Target feature '${target}' not found"
        echo -e "${RED}Error: Target feature '${target}' not found${NC}" >&2
        exit 1
    fi

    # Sync target worktree state before merging
    if [ "$target_is_active" = false ] && is_worktree_feature "$target"; then
        sync_from_worktree "$target"
    fi

    # Check uncommitted changes if target is active
    if [ "$target_is_active" = true ]; then
        if ! check_uncommitted; then
            _is_json && _json_error "Uncommitted changes detected. Commit or stash them first."
            echo -e "${RED}Error: You have uncommitted changes. Commit or stash them first.${NC}" >&2
            exit 1
        fi
    fi

    # --- Build preview ---
    if ! _is_json; then
        echo -e "${BOLD}Merge Preview${NC}"
        echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "  Source: ${CYAN}${source}${NC}$([ "$source_archived" = true ] && echo " (archived)")"
        echo -e "  Target: ${GREEN}${target}${NC}$([ "$target_is_active" = true ] && echo " (active)")"
        echo ""
    fi

    # AGENTS.md
    local source_md="$source_dir/AGENTS.md"
    if [ "$target_is_active" = true ]; then
        local target_md="$CLAUDE_MD"
    else
        local target_md="$target_dir/AGENTS.md"
    fi

    if [ -f "$source_md" ] && [ -s "$source_md" ]; then
        local src_lines
        src_lines=$(wc -l < "$source_md" | tr -d ' ')
        _is_json || echo -e "  ${BLUE}AGENTS.md:${NC} ${src_lines} lines will be appended"
    else
        _is_json || echo -e "  ${YELLOW}AGENTS.md:${NC} (empty or missing — nothing to merge)"
    fi

    # Tasks
    local source_tasks="$source_dir/tasks"
    if [ "$target_is_active" = true ]; then
        local target_tasks="$TASKS_DIR"
    else
        local target_tasks="$target_dir/tasks"
    fi

    local task_items=()
    for tf in todo.md lessons.md; do
        if [ -f "$source_tasks/$tf" ] && [ -s "$source_tasks/$tf" ]; then
            local tf_lines
            tf_lines=$(wc -l < "$source_tasks/$tf" | tr -d ' ')
            task_items+=("$tf (${tf_lines} lines)")
        fi
    done
    if [ ${#task_items[@]} -gt 0 ]; then
        _is_json || echo -e "  ${BLUE}Tasks:${NC} $(IFS=', '; echo "${task_items[*]}")"
    else
        _is_json || echo -e "  ${YELLOW}Tasks:${NC} (nothing to merge)"
    fi

    # Docs
    local source_docs=""
    if [ -d "$DOCS_DIR/$source" ]; then
        source_docs="$DOCS_DIR/$source"
    elif [ -d "$DOCS_DIR/archived/$source" ]; then
        source_docs="$DOCS_DIR/archived/$source"
    fi

    local target_docs="$DOCS_DIR/$target"
    local doc_copy=()
    local doc_skip=()

    if [ -n "$source_docs" ] && [ -d "$source_docs" ]; then
        for f in "$source_docs"/*; do
            [ -e "$f" ] || continue
            local fname="$(basename "$f")"
            if [ -e "$target_docs/$fname" ]; then
                doc_skip+=("$fname")
            else
                doc_copy+=("$fname")
            fi
        done
    fi

    if ! _is_json; then
        if [ ${#doc_copy[@]} -gt 0 ]; then
            echo -e "  ${BLUE}Docs:${NC} ${#doc_copy[@]} file(s) will be copied"
        fi
        if [ ${#doc_skip[@]} -gt 0 ]; then
            echo -e "  ${YELLOW}Docs conflicts:${NC} ${#doc_skip[@]} file(s) skipped (already exist in target)"
            for f in "${doc_skip[@]}"; do
                echo -e "    ${YELLOW}⚠${NC} $f"
            done
        fi
        if [ ${#doc_copy[@]} -eq 0 ] && [ ${#doc_skip[@]} -eq 0 ]; then
            echo -e "  ${YELLOW}Docs:${NC} (none)"
        fi

        # Post-merge action
        echo ""
        if [ "$delete_source" = true ]; then
            echo -e "  Post-merge: ${RED}delete${NC} '${source}'"
        else
            echo -e "  Post-merge: ${BLUE}archive${NC} '${source}'"
        fi

        echo ""
        echo -en "${YELLOW}Proceed with merge?${NC} [y/N] "
        read -r response

        if [[ ! "$response" =~ ^[Yy]$ ]]; then
            echo "Aborted."
            return
        fi
    fi

    # --- Execute merge ---

    # 1. AGENTS.md
    if [ -f "$source_md" ] && [ -s "$source_md" ]; then
        if [ -f "$target_md" ] && [ -s "$target_md" ]; then
            printf '\n\n---\n<!-- Merged from: %s -->\n\n' "$source" >> "$target_md"
            cat "$source_md" >> "$target_md"
        else
            mkdir -p "$(dirname "$target_md")"
            cp "$source_md" "$target_md"
        fi
        local merged_md=true
        _is_json || echo -e "${GREEN}Merged AGENTS.md${NC}"
    else
        local merged_md=false
    fi

    # 2. Tasks
    local merged_tasks=false
    if [ -d "$source_tasks" ]; then
        mkdir -p "$target_tasks"
        for tf in todo.md lessons.md; do
            _merge_task_file "$source_tasks/$tf" "$target_tasks/$tf" "$source"
        done
        merged_tasks=true
        _is_json || echo -e "${GREEN}Merged tasks${NC}"
    fi

    # 3. Docs
    if [ ${#doc_copy[@]} -gt 0 ]; then
        mkdir -p "$target_docs"
        for f in "${doc_copy[@]}"; do
            cp -r "$source_docs/$f" "$target_docs/$f"
        done
        _is_json || echo -e "${GREEN}Copied ${#doc_copy[@]} doc file(s)${NC}"
    fi
    if [ ${#doc_skip[@]} -gt 0 ]; then
        _is_json || echo -e "${YELLOW}Skipped ${#doc_skip[@]} conflicting doc file(s)${NC}"
    fi

    # 3b. Deploy merged content to worktree if target is worktree-backed
    if [ "$target_is_active" = false ] && is_worktree_feature "$target"; then
        deploy_to_worktree "$target"
        _is_json || echo -e "${GREEN}Deployed merged content to worktree${NC}"
    fi

    # 4. Archive or delete source
    local post_action=""
    if [ "$delete_source" = true ]; then
        # Clean up worktree if source is worktree-backed
        if is_worktree_feature "$source"; then
            remove_worktree "$source" true
        fi
        rm -rf "$source_dir"
        [ -d "$DOCS_DIR/$source" ] && rm -rf "$DOCS_DIR/$source"
        [ -d "$DOCS_DIR/archived/$source" ] && rm -rf "$DOCS_DIR/archived/$source"
        rmdir "$DOCS_DIR/archived" 2>/dev/null || true
        rmdir "$FEATURES_DIR/archived" 2>/dev/null || true
        post_action="deleted"
        _is_json || echo -e "${GREEN}Deleted source feature '${source}'${NC}"
    elif [ "$source_archived" = true ]; then
        post_action="already_archived"
        _is_json || echo -e "${BLUE}Source '${source}' was already archived${NC}"
    else
        mkdir -p "$FEATURES_DIR/archived"
        mv "$source_dir" "$(get_archived_feature_dir "$source")"
        if [ -d "$DOCS_DIR/$source" ]; then
            mkdir -p "$DOCS_DIR/archived"
            mv "$DOCS_DIR/$source" "$DOCS_DIR/archived/$source"
        fi
        post_action="archived"
        _is_json || echo -e "${GREEN}Archived source feature '${source}'${NC}"
    fi

    if _is_json; then
        _json_emit "success" "@bool:true" "command" "merge" \
            "source" "$source" "target" "$target" \
            "merged" "@json:{\"claude_md\":$merged_md,\"tasks\":$merged_tasks,\"docs_copied\":${#doc_copy[@]},\"docs_skipped\":${#doc_skip[@]}}" \
            "post_action" "$post_action"
        return
    fi

    echo ""
    echo -e "${GREEN}Successfully merged '${source}' into '${target}'${NC}"
}

# Sync worktree feature context back to storage
sync_worktrees() {
    local name="$1"

    if [ -n "$name" ]; then
        # Sync specific feature
        if ! is_worktree_feature "$name"; then
            _is_json && _json_error "'${name}' is not a worktree-backed feature"
            echo -e "${RED}Error: '${name}' is not a worktree-backed feature${NC}" >&2
            exit 1
        fi
        local wt_path
        wt_path="$(get_worktree_path "$name")"
        if [ ! -d "$wt_path" ]; then
            _is_json && _json_error "Worktree directory missing: ${wt_path}"
            echo -e "${RED}Error: Worktree directory missing: ${wt_path}${NC}" >&2
            exit 1
        fi
        sync_from_worktree "$name"

        if _is_json; then
            _json_emit "success" "@bool:true" "command" "sync" \
                "feature" "$name" "worktree_path" "$wt_path"
            return
        fi
        echo -e "${GREEN}Synced '${name}' from worktree${NC}"
    else
        # Sync all worktree features
        local count=0
        local synced=()
        for feature in $(get_features); do
            if is_worktree_feature "$feature"; then
                local wt_path
                wt_path="$(get_worktree_path "$feature")"
                if [ -d "$wt_path" ]; then
                    sync_from_worktree "$feature"
                    count=$((count + 1))
                    synced+=("$feature")
                    _is_json || echo -e "${GREEN}Synced '${feature}'${NC}"
                else
                    _is_json || echo -e "${YELLOW}Skipped '${feature}' — worktree dir missing${NC}"
                fi
            fi
        done

        if _is_json; then
            local synced_str=""
            synced_str=$(printf '%s\n' "${synced[@]}")
            _json_emit "success" "@bool:true" "command" "sync" \
                "count" "@int:$count" "synced" "@array:$synced_str"
            return
        fi

        if [ "$count" -eq 0 ]; then
            echo -e "${YELLOW}No worktree features to sync${NC}"
        else
            echo -e "${GREEN}Synced ${count} worktree feature(s)${NC}"
        fi
    fi
}

# Print the worktree path for a feature (pipe-friendly)
open_worktree() {
    local name="$1"

    if [ -z "$name" ]; then
        _is_json && _json_error "Please provide a feature name"
        echo -e "${RED}Error: Please provide a feature name${NC}" >&2
        echo "Usage: cody-switch open <name>" >&2
        exit 1
    fi

    if ! is_worktree_feature "$name"; then
        _is_json && _json_error "'${name}' is not a worktree-backed feature"
        echo -e "${RED}Error: '${name}' is not a worktree-backed feature${NC}" >&2
        exit 1
    fi

    local wt_path
    wt_path="$(get_worktree_path "$name")"

    if [ ! -d "$wt_path" ]; then
        _is_json && _json_error "Worktree directory missing: ${wt_path}"
        echo -e "${RED}Error: Worktree directory missing: ${wt_path}${NC}" >&2
        exit 1
    fi

    if _is_json; then
        _json_emit "success" "@bool:true" "command" "open" \
            "feature" "$name" "worktree_path" "$wt_path"
        return
    fi

    # Print just the path (pipe-friendly: cd $(cody-switch open feat))
    echo "$wt_path"
}

# Dispatch switch command: resolves numbers, collects --with args
_dispatch_switch() {
    local primary=""
    local switch_args=()
    local expect_with_value=false
    local features=($(get_features))

    # Resolve a number or name to a feature name
    _resolve_feature() {
        local val="$1"
        if [[ "$val" =~ ^[0-9]+$ ]]; then
            local idx=$(($val - 1))
            if [ $idx -lt 0 ] || [ $idx -ge ${#features[@]} ]; then
                echo -e "${RED}Error: Invalid number $val. Use 1-${#features[@]}${NC}" >&2
                exit 1
            fi
            echo "${features[$idx]}"
        else
            echo "$val"
        fi
    }

    for arg in "$@"; do
        if [ "$expect_with_value" = true ]; then
            switch_args+=("--with" "$(_resolve_feature "$arg")")
            expect_with_value=false
        elif [ "$arg" = "--with" ]; then
            expect_with_value=true
        elif [[ "$arg" == --with=* ]]; then
            switch_args+=("--with" "$(_resolve_feature "${arg#--with=}")")
        elif [ -z "$primary" ]; then
            primary="$(_resolve_feature "$arg")"
        fi
    done

    if [ "$expect_with_value" = true ]; then
        echo -e "${RED}Error: --with requires a feature name or number${NC}" >&2
        exit 1
    fi

    switch_to "$primary" "${switch_args[@]}"
}

# Main
case "${1:-list}" in
    list|ls|-l)
        list_features "$2"
        ;;
    current|-c)
        if _is_json; then
            _refs=""
            [ -f "$WITH_REFS_FILE" ] && _refs=$(paste -sd $'\n' "$WITH_REFS_FILE")
            _json_emit "success" "@bool:true" "command" "current" \
                "feature" "$(get_current)" "branch" "$(get_branch)" \
                "refs" "@array:$_refs"
        else
            current_feature="$(get_current)"
            echo -e "Current branch:  ${CYAN}$(get_branch)${NC}"
            echo -e "Current feature: ${GREEN}${current_feature}${NC}"
            if [ -f "$WITH_REFS_FILE" ]; then
                echo -e "With references: ${BLUE}$(paste -sd ', ' "$WITH_REFS_FILE")${NC}"
            fi
            if [ "$current_feature" != "(none)" ] && [ "$current_feature" != "(active but untracked)" ]; then
                restore_session "$current_feature"
            fi
        fi
        ;;
    new|create|-n)
        create_new "$2"
        ;;
    blank|-b)
        shift
        create_blank "$@"
        ;;
    fork|-f)
        shift
        fork_feature "$@"
        ;;
    peek|show|cat)
        peek_feature "$2"
        ;;
    archive)
        archive_feature "$2"
        ;;
    unarchive)
        unarchive_feature "$2"
        ;;
    delete|rm)
        delete_feature "$2"
        ;;
    pin-session|pin)
        pin_session
        ;;
    promote-lesson|promote)
        promote_lesson "$2"
        ;;
    promote-audit|audit)
        promote_audit
        ;;
    merge|-m)
        shift
        merge_feature "$@"
        ;;
    doctor|health|diagnose)
        doctor "$2"
        ;;
    save)
        save_command
        ;;
    sync)
        sync_worktrees "$2"
        ;;
    open)
        open_worktree "$2"
        ;;
    init)
        shift
        init_project "$@"
        ;;
    help|-h|--help)
        show_help
        ;;
    *)
        _dispatch_switch "$@"
        ;;
esac
