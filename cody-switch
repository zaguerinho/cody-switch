<!-- Add testing instructions: framework, run command, conventions -->
EOF
            ;;
    esac
}

# Append missing cody-switch entries to .gitignore
_init_gitignore() {
    local gitignore="$PROJECT_DIR/.gitignore"
    local entries=(".codex-current-feature" ".codex-last-seen-feature" ".codex-with-refs" "tasks/" ".codex/worktrees/" "AGENTS.md" ".codex/batch/")
    local missing=()

    for entry in "${entries[@]}"; do
        if [ ! -f "$gitignore" ] || ! grep -qxF "$entry" "$gitignore" 2>/dev/null; then
            missing+=("$entry")
        fi
    done

    if [ ${#missing[@]} -eq 0 ]; then
        _is_json || echo -e "  ${GREEN}.gitignore${NC}             already has cody-switch entries"
        return 0
    fi

    # Ensure trailing newline before appending
    if [ -f "$gitignore" ] && [ -s "$gitignore" ]; then
        # Add newline if file doesn't end with one
        if [ "$(tail -c1 "$gitignore" | wc -l)" -eq 0 ]; then
            echo "" >> "$gitignore"
        fi
        echo "" >> "$gitignore"
    fi

    echo "# cody-switch" >> "$gitignore"
    for entry in "${missing[@]}"; do
        echo "$entry" >> "$gitignore"
    done
    _is_json || echo -e "  ${GREEN}.gitignore${NC}             ${#missing[@]} entries added"
}

