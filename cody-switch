> Global lessons are in \`.codex/features/lessons-global.md\` — read them at session start.

_(capture corrections and patterns here)_
SCAFFOLD
        else
            cat > "$target/lessons.md" << 'SCAFFOLD'
# Lessons Learned

_(capture corrections and patterns here)_
SCAFFOLD
        fi
    fi
    _is_json || echo -e "${BLUE}Created fresh tasks/ scaffold${NC}"
}

# Create a minimal AGENTS.md scaffold for a feature
_create_claude_scaffold() {
    local name="$1"
    local dest="$2"
    cat > "$dest" << SCAFFOLD
# Feature: ${name}

<!-- Add feature-specific context here -->
SCAFFOLD
